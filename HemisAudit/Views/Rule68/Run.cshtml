@using System.Globalization
@model HemisAudit.ViewModels.Rule68RunReviewViewModel
@{
    ViewData["Title"] = $"Rule 68 Run {Model.RunId}";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var canDownload      = ViewBag.CanDownloadSavedRun is bool d && d;
    var canOpenWorkspace = ViewBag.CanOpenWorkspace    is bool o && o;
    var isArchived       = ViewBag.IsArchived          is bool a && a;
    var moduleNavigation = ViewBag.ModuleNavigation as HemisAudit.ViewModels.ModuleSequenceNavigationViewModel;
    var creditsCol       = string.IsNullOrWhiteSpace(Model.Summary.CredCreditsCol) ? "_036" : Model.Summary.CredCreditsCol;
    var hasDetail        = !string.IsNullOrWhiteSpace(Model.Summary.DetailTable);
}

@if (TempData["Success"] != null)
{
    <div class="alert alert--success" style="margin-bottom:16px">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert--error" style="margin-bottom:16px">@TempData["Error"]</div>
}

@if (moduleNavigation != null)
{
    @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
}

<div class="page-header">
    <div>
        <h1>Rule 68 — Saved Run #@Model.RunId</h1>
        <p>@Model.EngagementName &nbsp;|&nbsp; @Model.MaconomyNumber</p>
    </div>
    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
        @if (canOpenWorkspace)
        {
            <a href="/Rule68?clientId=@Model.ClientId" class="btn btn-secondary">Open Workspace</a>
        }
        @if (canDownload)
        {
            <a href="/Rule68/DownloadSavedExcel?runId=@Model.RunId" class="btn btn-info">Download Excel</a>
            <a href="/Rule68/DownloadSavedCsv?runId=@Model.RunId" class="btn btn-info">Download CSV</a>
            <a href="/Rule68/DownloadSavedSql?runId=@Model.RunId" class="btn btn-secondary">Download SQL</a>
        }
    </div>
</div>

<div class="card" style="padding:20px;margin-bottom:20px">
    <h3 class="section-title" style="margin-top:0">Run Summary</h3>
    <div class="form-grid">
        <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Database</div><div>@Model.Summary.Database</div></div>
        <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">CREG Table</div><div>@Model.Summary.CregTable</div></div>
        <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">CRED Table</div><div>@Model.Summary.CredTable</div></div>
        <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Credits Column</div><div><code>CRED.[@creditsCol]</code></div></div>
        <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Threshold</div><div>SUM &gt; @((Model.Summary.MaxTotalCredits > 0 ? Model.Summary.MaxTotalCredits.ToString("0.##", CultureInfo.InvariantCulture) : "1.0")) = FAIL (03603)</div></div>
        <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Timestamp</div><div>@Model.Summary.Timestamp</div></div>
        <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Status</div><div><span class="badge @(Model.Summary.Status == "PASS" ? "badge--pass" : "badge--fail")">@Model.Summary.Status</span></div></div>
        @if (hasDetail)
        {
            <div><div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Detail Table</div><div>@Model.Summary.DetailTable</div></div>
        }
    </div>
    <div class="stats-grid" style="margin-top:16px">
        <div class="stat-card"><div class="stat-card__label">CREG Records</div><div class="stat-card__value">@Model.Summary.CregRecordCount.ToString("N0")</div></div>
        <div class="stat-card"><div class="stat-card__label">CRED Records</div><div class="stat-card__value">@Model.Summary.CredRecordCount.ToString("N0")</div></div>
        <div class="stat-card"><div class="stat-card__label">Student-Qual Pairs Checked</div><div class="stat-card__value">@Model.Summary.TotalValidated.ToString("N0")</div></div>
        <div class="stat-card stat-card--pass"><div class="stat-card__label">PASS (&le; @((Model.Summary.MaxTotalCredits > 0 ? Model.Summary.MaxTotalCredits.ToString("0.##", CultureInfo.InvariantCulture) : "1.0")))</div><div class="stat-card__value">@Model.Summary.PassCount.ToString("N0")</div></div>
        <div class="stat-card stat-card--fail"><div class="stat-card__label">FAIL (03603)</div><div class="stat-card__value">@Model.Summary.FailCount.ToString("N0")</div></div>
        <div class="stat-card stat-card--fail"><div class="stat-card__label">Exception Rate</div><div class="stat-card__value">@Model.Summary.ExceptionRate.ToString("0.00")%</div></div>
        @if (hasDetail)
        {
            <div class="stat-card" style="border-left:4px solid #2e7d32"><div class="stat-card__label">Confirmed by Rule 32</div><div class="stat-card__value" style="color:#2e7d32">@Model.Summary.ConfirmedByRule32Count.ToString("N0")</div></div>
            <div class="stat-card" style="border-left:4px solid #f57f17"><div class="stat-card__label">Not in Rule 32</div><div class="stat-card__value" style="color:#f57f17">@Model.Summary.NotInRule32Count.ToString("N0")</div></div>
            <div class="stat-card" style="border-left:4px solid #880e4f"><div class="stat-card__label">Rule 32 Detail (03603)</div><div class="stat-card__value" style="color:#880e4f">@Model.Summary.Rule32OnlyCount.ToString("N0")</div></div>
        }
    </div>
</div>

@if (Model.Signoffs.Any())
{
    <div class="card" style="padding:20px;margin-bottom:20px">
        <h3 class="section-title" style="margin-top:0">Signoffs</h3>
        <table class="data-table">
            <thead><tr><th>Role</th><th>Reviewer</th><th>Signed Off At</th><th>Comment</th></tr></thead>
            <tbody>
                @foreach (var s in Model.Signoffs)
                {
                    <tr>
                        <td>@s.SignoffRole</td>
                        <td>@s.ReviewerName</td>
                        <td>@s.SignedOffAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@s.Comment</td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!isArchived && Model.CanCurrentUserSignOff && !Model.CurrentUserHasSignedOff && Model.IsCurrentRun)
        {
            <form method="post" action="/Rule68/AddSignoff" style="margin-top:16px">
                @Html.AntiForgeryToken()
                <input type="hidden" name="runId" value="@Model.RunId" />
                <div class="field-group"><label>Signoff Comment</label><textarea name="comment" rows="3" placeholder="Add review notes"></textarea></div>
                <button type="submit" class="btn btn-primary">Sign Off</button>
            </form>
        }
        @if (!isArchived && Model.CanCurrentUserRemoveSignoff && Model.IsCurrentRun)
        {
            <form method="post" action="/Rule68/RemoveSignoff" style="margin-top:8px">
                @Html.AntiForgeryToken()
                <input type="hidden" name="runId" value="@Model.RunId" />
                <button type="submit" class="btn btn-warning" onclick="return confirm('Remove your signoff?')">Remove Signoff</button>
            </form>
        }
    </div>
}

<div class="card" style="padding:20px;margin-bottom:20px">
    <h3 class="section-title" style="margin-top:0">Result Rows <small style="font-weight:normal;font-size:13px">(browser preview)</small></h3>
    @if (Model.Summary.IsPreviewOnly)
    {
        <div class="alert alert--warning" style="margin-bottom:12px">Showing a preview of @Model.Summary.PreviewLimit rows. Download Excel or CSV for the full result set.</div>
    }
    <div class="table-wrapper" style="overflow-x:auto">
        <table class="data-table" style="min-width:700px;font-size:12px;font-family:Consolas,monospace">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Student No</th>
                    <th>Qual Code</th>
                    <th>Qual Name</th>
                    <th>Course Count</th>
                    <th>Total @creditsCol</th>
                    <th>Result</th>
                    <th>Error Code</th>
                    @if (hasDetail) { <th>Reconciliation</th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Summary.ReviewRows)
                {
                    var dv = row.DisplayValues;
                    string DV(string k) => dv.TryGetValue(k, out var val) ? (val ?? "") : "";
                    var isFail = row.ValidationResult == "FAIL";
                    <tr style="background:@(isFail ? "#FFF3F3" : "#F3FFF3")">
                        <td>@row.ValidationNumber</td>
                        <td style="font-weight:@(isFail?"700":"400");color:@(isFail?"#b71c1c":"inherit")">@DV("Student_No")</td>
                        <td>@DV("Qual_Code")</td>
                        <td>@DV("Qual_Name")</td>
                        <td>@DV("Course_Count")</td>
                        <td style="font-weight:700;color:@(isFail?"#b71c1c":"#2e7d32")">@DV("Total_Credits")</td>
                        <td style="font-weight:700;color:@(isFail?"#b71c1c":"#2e7d32")">@row.ValidationResult</td>
                        <td>@row.ErrorCode</td>
                        @if (hasDetail) { <td>@row.ReconciliationStatus</td> }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (hasDetail && Model.Summary.Rule32OnlyRows.Any())
{
    <div class="card" style="padding:20px;margin-bottom:20px">
        <h3 class="section-title" style="margin-top:0">Rule 32 Detail — 03603 Records (preview)</h3>
        <p style="font-size:13px;color:var(--text-muted);margin:0 0 12px">
            Records in <strong>@Model.Summary.DetailTable</strong> with error 03603.
            <span style="color:#2e7d32;font-weight:700">Green</span> = confirmed by Rule 68 FAIL.
        </p>
        <div class="table-wrapper" style="overflow-x:auto">
            <table class="data-table" style="font-size:12px;font-family:Consolas,monospace">
                <thead><tr><th>#</th><th>Student No (Rule 32)</th><th>Qual Code (Rule 32)</th><th>Sum Credits</th><th>Confirmed by R68?</th></tr></thead>
                <tbody>
                    @foreach (var row in Model.Summary.Rule32OnlyRows)
                    {
                        var confirmed = row.ConfirmedByR68 == "Yes";
                        <tr style="background:@(confirmed ? "#E8F5E9" : "#FCE4EC")">
                            <td>@row.RowNumber</td>
                            <td style="font-weight:700;color:@(confirmed?"#2e7d32":"#880e4f")">@row.StudentNo</td>
                            <td>@row.QualCode</td>
                            <td>@row.SumCredits</td>
                            <td style="font-weight:700;color:@(confirmed?"#2e7d32":"#880e4f")">@row.ConfirmedByR68</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.GeneratedSql))
{
    <div class="card" style="padding:20px">
        <h3 class="section-title" style="margin-top:0">Generated SQL</h3>
        <textarea readonly rows="20" style="width:100%;font-family:Consolas,monospace;font-size:12px;background:var(--bg-code,#f8f8f8);border:1px solid var(--border,#e5e7eb);border-radius:8px;padding:12px">@Model.GeneratedSql</textarea>
    </div>
}
