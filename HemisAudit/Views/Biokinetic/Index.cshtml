@using HemisAudit.Models
@using HemisAudit.ViewModels
@{
    ViewData["Title"] = "Biokinetic Module - Qualification & Surname Validation";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var clients = ViewBag.Clients as List<Client> ?? new();
    var selectedClientId = ViewBag.ClientId is int clientId ? clientId : 0;
    var currentSystemRole = ViewBag.CurrentSystemRole as string ?? "";
    var isResultsOnlyRole =
        string.Equals(currentSystemRole, "Manager", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Director", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Trainee", StringComparison.OrdinalIgnoreCase);
    var moduleNavigation = ViewBag.ModuleNavigation as ModuleSequenceNavigationViewModel;
}

<style>
    .bk-results-grid { display: grid; gap: 16px; }
    .bk-metric-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 16px; }
    .bk-metric-value { font-size: 24px; font-weight: 700; color: var(--primary); }
    .bk-metric-label { font-size: 12px; text-transform: uppercase; color: var(--text-muted); margin-top: 4px; }
    .bk-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .bk-table th { background: var(--primary); color: white; padding: 8px; text-align: left; }
    .bk-table td { padding: 6px 8px; border-bottom: 1px solid var(--border-color); }
    .bk-table tr:hover { background: var(--hover-bg); }
    .bk-pass { color: #28a745; font-weight: 700; }
    .bk-fail { color: #dc3545; font-weight: 700; }
</style>

<div id="app" class="rule-page-shell">
    @if (moduleNavigation != null)
    {
        @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
    }

    <div class="engagement-selector">
        <label for="bkClientId">Engagement</label>
        <select id="bkClientId">
            <option value="">Select engagement</option>
            @foreach (var client in clients)
            {
                <option value="@client.Id" selected="@(client.Id == selectedClientId ? "selected" : null)">
                    @client.Name (@client.FiscalYear)
                </option>
            }
        </select>
        <small>Biokinetic validates QUALIFICATION values from Biokinetic table against Clinical Production table and confirms Surname matching.</small>
    </div>

    <div class="rule-header">
        <div class="rule-header__icon">BK</div>
        <div>
            <h1 class="rule-header__title">Biokinetic Module: Qualification & Surname Validation</h1>
            <p class="rule-header__sub">
                Checks that QUALIFICATION values from Biokinetic table exist in Clinical Production table.
                When QUALIFICATION is found, confirms matching Surname records.
            </p>
        </div>
        <div class="rule-header__badge" id="bkStatusBadge" style="display:none"></div>
    </div>

    @if (!isResultsOnlyRole)
    {
        <div class="accordion-stack">
            <div class="accordion-item">
                <button class="accordion-toggle" type="button" onclick="window.toggleAccordion('bk-conn')">
                    <span class="acc-icon">DB</span><span>Database Connection</span><span class="acc-chevron">v</span>
                </button>
                <div class="accordion-body" id="body-bk-conn">
                    <div class="form-grid">
                        <div class="field-group">
                            <label for="bkServer">Server Name</label>
                            <input id="bkServer" type="text" placeholder="e.g. MYSERVER\INSTANCE or (localdb)\MSSQLLocalDB" />
                        </div>
                        <div class="field-group">
                            <label for="bkDriver">Driver</label>
                            <select id="bkDriver">
                                <option value="ODBC Driver 17 for SQL Server">ODBC Driver 17 for SQL Server</option>
                                <option value="ODBC Driver 18 for SQL Server">ODBC Driver 18 for SQL Server</option>
                                <option value="SQL Server">SQL Server</option>
                            </select>
                        </div>
                        <div class="field-group">
                            <label for="bkDatabase">Database</label>
                            <select id="bkDatabase"></select>
                        </div>
                    </div>
                    <div class="action-bar" style="justify-content:flex-start; margin:12px 0 0">
                        <button type="button" class="btn btn-primary" id="bkConnectBtn">Connect</button>
                    </div>
                    <div id="bkConnectionOutput" class="status-output"></div>
                </div>
            </div>

            <div class="accordion-item">
                <button class="accordion-toggle" type="button" onclick="window.toggleAccordion('bk-config')">
                    <span class="acc-icon">CF</span><span>Table & Column Configuration</span><span class="acc-chevron">v</span>
                </button>
                <div class="accordion-body" id="body-bk-config" style="display:none">
                    <div class="info-box info-box--blue">
                        <strong>Biokinetic Module Logic:</strong><br />
                        Compare QUALIFICATION and Surname columns from Biokinetic table against Clinical Production table.
                        Records PASS when the QUALIFICATION exists in the production table; FAIL when missing.
                    </div>
                    <div class="form-grid">
                        <div class="field-group">
                            <label for="bkBiokinieticTable">Biokinetic Table</label>
                            <select id="bkBiokinieticTable" onchange="window.bkLoadColumns('biokinetic', this.value)"></select>
                        </div>
                        <div class="field-group">
                            <label for="bkProductionTable">Clinical Production Table</label>
                            <select id="bkProductionTable" onchange="window.bkLoadColumns('production', this.value)"></select>
                        </div>
                    </div>
                    <div class="form-grid" style="margin-top:12px">
                        <div class="field-group">
                            <label for="bkQualificationColumn">QUALIFICATION Column</label>
                            <select id="bkQualificationColumn"></select>
                        </div>
                        <div class="field-group">
                            <label for="bkSurnameColumn">Surname Column</label>
                            <select id="bkSurnameColumn"></select>
                        </div>
                    </div>
                    <div class="action-bar" style="justify-content:flex-start; margin:10px 0 0">
                        <button type="button" class="btn btn-secondary" onclick="window.bkAutoDetectColumns()">Auto-Detect Columns</button>
                    </div>
                    <div id="bkConfigOutput" class="status-output"></div>
                </div>
            </div>
        </div>
    }

    <div class="workspace-signoff-card">
        <div class="workspace-signoff-card__header">
            <div>
                <div class="workspace-signoff-card__title">Saved Workspace</div>
                <div class="workspace-signoff-card__subtitle">Biokinetic connection and validation results auto-load for this engagement.</div>
            </div>
            <div id="bkWorkspaceRunState" class="badge badge--neutral badge--sm">No saved run</div>
        </div>
        <div id="bkWorkspaceInfo" class="alert alert--info">Select an engagement to load the Biokinetic workspace.</div>
        <div class="workspace-signoff-grid">
            <div>
                <div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Current Run</div>
                <div id="bkWorkspaceRunLabel">No saved run yet</div>
            </div>
            <div>
                <div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Status</div>
                <div id="bkWorkspaceStatusLabel">-</div>
            </div>
            <div>
                <div style="color:var(--text-muted);font-size:12px;text-transform:uppercase;font-weight:700">Last Run</div>
                <div id="bkWorkspaceLastRunLabel">-</div>
            </div>
            <div class="field-group" style="grid-column:1 / -1">
                <label for="bkWorkspaceComment">Notes</label>
                <textarea id="bkWorkspaceComment" rows="2" placeholder="Add validation notes"></textarea>
            </div>
        </div>
        <div class="workspace-signoff-actions">
            @if (!isResultsOnlyRole)
            {
                <button type="button" class="btn btn-success" id="bkSaveWorkspaceBtn">Save Workspace</button>
            }
        </div>
    </div>

    @if (!isResultsOnlyRole)
    {
        <div class="action-bar">
            <button type="button" class="btn btn-info" id="bkVerifyBtn">Verify Tables</button>
            <button type="button" class="btn btn-success" id="bkRunBtn">Run Biokinetic</button>
            <button type="button" class="btn btn-primary" id="bkSqlBtn">Generate SQL</button>
        </div>
    }

    <div class="results-panel">
        <div class="results-tabs">
            <button class="tab-btn active" type="button" data-tab="analysis">Analysis</button>
            <button class="tab-btn" type="button" data-tab="results">Results</button>
            <button class="tab-btn" type="button" data-tab="sql">SQL</button>
        </div>
        <div class="tab-pane active" data-tab-panel="analysis" id="bkAnalysisPane"></div>
        <div class="tab-pane" data-tab-panel="results" id="bkResultsPane"></div>
        <div class="tab-pane" data-tab-panel="sql">
            <textarea id="bkSqlText" rows="20" readonly></textarea>
        </div>
    </div>

    <div id="bkSpinner" class="spinner-overlay" style="display:none">
        <div class="spinner-box">
            <div class="spinner-ring"></div>
            <p id="bkSpinnerMsg">Processing...</p>
        </div>
    </div>
</div>

<form id="bkAntiForgeryForm" method="post" style="display:none">@Html.AntiForgeryToken()</form>

<script>
window.toggleAccordion = function(id) {
    const body = document.getElementById(`body-${id}`);
    if (body) body.style.display = body.style.display === 'none' ? '' : 'none';
};

window.bkLoadColumns = async function(role, tableName) {
    const server = document.getElementById('bkServer')?.value?.trim();
    const db = document.getElementById('bkDatabase')?.value;
    if (!server || !db || !tableName) return;

    try {
        const data = await postJson('/Biokinetic/GetColumns', {
            server, database: db, driver: document.getElementById('bkDriver')?.value || 'ODBC Driver 17 for SQL Server',
            biokinieticTable: tableName
        });
        if (!data.success || !data.columns) return;

        const cols = data.columns || [];
        if (role === 'biokinetic') {
            fillColSel(document.getElementById('bkQualificationColumn'), cols, 'QUALIFICATION');
            fillColSel(document.getElementById('bkSurnameColumn'), cols, 'Surname');
        }
    } catch (err) { console.error('Column load failed:', err); }
};

window.bkAutoDetectColumns = function() {
    const qCol = document.getElementById('bkQualificationColumn');
    const sCol = document.getElementById('bkSurnameColumn');
    if (qCol?.options.length > 0 && !qCol.value) qCol.value = qCol.options[0].value;
    if (sCol?.options.length > 0 && !sCol.value) sCol.value = sCol.options[0].value;
    document.getElementById('bkConfigOutput').innerHTML = '<div class="alert alert--success">Column detection complete.</div>';
};

const bkToken = document.querySelector('#bkAntiForgeryForm input[name="__RequestVerificationToken"]')?.value || '';

async function postJson(url, data) {
    const resp = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': bkToken },
        body: JSON.stringify(data)
    });
    return await resp.json();
}

function showSpinner(msg) {
    document.getElementById('bkSpinnerMsg').textContent = msg || 'Processing...';
    document.getElementById('bkSpinner').style.display = 'flex';
}

function hideSpinner() {
    document.getElementById('bkSpinner').style.display = 'none';
}

function setAlert(target, type, message) {
    if (target) target.innerHTML = `<div class="alert alert--${type}">${message}</div>`;
}

function populateSelect(sel, values, selected) {
    if (!sel) return;
    sel.innerHTML = '<option value="">Select table</option>';
    values.forEach(v => {
        const o = document.createElement('option');
        o.value = o.textContent = v;
        sel.appendChild(o);
    });
    if (selected) sel.value = selected;
}

function fillColSel(sel, cols, preferred) {
    if (!sel) return;
    sel.innerHTML = '';
    (cols || []).forEach(c => {
        const o = document.createElement('option');
        o.value = o.textContent = c;
        if (c === preferred) o.selected = true;
        sel.appendChild(o);
    });
}

// Tab switching
document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
        this.classList.add('active');
        const tab = this.dataset.tab;
        document.querySelector(`[data-tab-panel="${tab}"]`)?.classList.add('active');
    });
});

document.getElementById('bkConnectBtn')?.addEventListener('click', async function() {
    const server = document.getElementById('bkServer')?.value?.trim();
    const driver = document.getElementById('bkDriver')?.value;
    if (!server) return setAlert(document.getElementById('bkConnectionOutput'), 'error', 'Enter server name');

    showSpinner('Connecting...');
    try {
        const data = await postJson('/Biokinetic/GetDatabases', { server, driver });
        hideSpinner();
        if (data.success) {
            populateSelect(document.getElementById('bkDatabase'), data.databases || []);
            setAlert(document.getElementById('bkConnectionOutput'), 'success', `Connected. Found ${data.databases?.length || 0} databases.`);
            document.getElementById('bkDatabase').addEventListener('change', async function() {
                if (!this.value) return;
                showSpinner('Loading tables...');
                const tableData = await postJson('/Biokinetic/GetTables', { server, database: this.value, driver });
                hideSpinner();
                if (tableData.success) {
                    populateSelect(document.getElementById('bkBiokinieticTable'), tableData.tables || [], tableData.autoBiokinieticTable);
                    populateSelect(document.getElementById('bkProductionTable'), tableData.tables || [], tableData.autoProductionTable);
                }
            });
        } else {
            setAlert(document.getElementById('bkConnectionOutput'), 'error', data.error || 'Connection failed');
        }
    } catch (err) {
        hideSpinner();
        setAlert(document.getElementById('bkConnectionOutput'), 'error', err.message);
    }
});

document.getElementById('bkRunBtn')?.addEventListener('click', async function() {
    const clientId = parseInt(document.getElementById('bkClientId')?.value || '0');
    if (!clientId) return setAlert(document.getElementById('bkAnalysisPane'), 'error', 'Select an engagement');

    showSpinner('Running validation...');
    try {
        const data = await postJson('/Biokinetic/RunValidation', {
            clientId,
            server: document.getElementById('bkServer')?.value?.trim(),
            database: document.getElementById('bkDatabase')?.value,
            driver: document.getElementById('bkDriver')?.value,
            biokinieticTable: document.getElementById('bkBiokinieticTable')?.value,
            productionTable: document.getElementById('bkProductionTable')?.value,
            qualificationColumn: document.getElementById('bkQualificationColumn')?.value,
            surnameColumn: document.getElementById('bkSurnameColumn')?.value
        });
        hideSpinner();
        if (data.success) {
            const html = `<div class="bk-results-grid">
                <div class="bk-metric-card"><div class="bk-metric-value">${data.totalValidated}</div><div class="bk-metric-label">Records Validated</div></div>
                <div class="bk-metric-card"><div class="bk-metric-value" style="color: #28a745">${data.passCount}</div><div class="bk-metric-label">Pass</div></div>
                <div class="bk-metric-card"><div class="bk-metric-value" style="color: #dc3545">${data.failCount}</div><div class="bk-metric-label">Fail</div></div>
                <div class="bk-metric-card"><div class="bk-metric-value">${data.exceptionRate}%</div><div class="bk-metric-label">Exception Rate</div></div>
            </div>`;
            document.getElementById('bkAnalysisPane').innerHTML = html;

            if (data.reviewRows?.length > 0) {
                let rows = data.reviewRows.map(r =>
                    `<tr><td>${r.biokinieticQualification}</td><td>${r.biokinieticSurname}</td>
                     <td class="${r.status === 'PASS' ? 'bk-pass' : 'bk-fail'}">${r.status}</td>
                     <td>${r.productionQualification}</td><td>${r.productionSurname}</td></tr>`
                ).join('');
                document.getElementById('bkResultsPane').innerHTML =
                    `<table class="bk-table"><thead><tr>
                        <th>Biokinetic QUALIFICATION</th><th>Biokinetic Surname</th>
                        <th>Status</th><th>Production QUALIFICATION</th><th>Production Surname</th>
                    </tr></thead><tbody>${rows}</tbody></table>`;
            }

            document.getElementById('bkStatusBadge').style.display = 'inline-block';
            document.getElementById('bkStatusBadge').textContent = data.status;
            document.getElementById('bkStatusBadge').className = data.status === 'PASS' ? 'badge--pass' : 'badge--fail';

            if (data.warning) {
                document.getElementById('bkWorkspaceInfo').innerHTML = `<div class="alert alert--warning">${data.warning}</div>`;
            }
        } else {
            setAlert(document.getElementById('bkAnalysisPane'), 'error', data.error || 'Validation failed');
        }
    } catch (err) {
        hideSpinner();
        setAlert(document.getElementById('bkAnalysisPane'), 'error', err.message);
    }
});

document.getElementById('bkVerifyBtn')?.addEventListener('click', async function() {
    showSpinner('Verifying tables...');
    try {
        const data = await postJson('/Biokinetic/VerifyTables', {
            server: document.getElementById('bkServer')?.value?.trim(),
            database: document.getElementById('bkDatabase')?.value,
            driver: document.getElementById('bkDriver')?.value,
            biokinieticTable: document.getElementById('bkBiokinieticTable')?.value,
            productionTable: document.getElementById('bkProductionTable')?.value,
            qualificationColumn: document.getElementById('bkQualificationColumn')?.value,
            surnameColumn: document.getElementById('bkSurnameColumn')?.value
        });
        hideSpinner();
        if (data.success) {
            setAlert(document.getElementById('bkConfigOutput'), 'success',
                `Biokinetic: ${data.biokinieticRecordCount} records | Production: ${data.productionRecordCount} records | Matched: ${data.matchedCount} | Missing: ${data.missingCount}`);
        } else {
            setAlert(document.getElementById('bkConfigOutput'), 'error', data.error);
        }
    } catch (err) {
        hideSpinner();
        setAlert(document.getElementById('bkConfigOutput'), 'error', err.message);
    }
});

document.getElementById('bkSqlBtn')?.addEventListener('click', async function() {
    showSpinner('Generating SQL...');
    try {
        const data = await postJson('/Biokinetic/GenerateSql', {
            clientId: parseInt(document.getElementById('bkClientId')?.value || '0'),
            server: document.getElementById('bkServer')?.value?.trim(),
            database: document.getElementById('bkDatabase')?.value,
            driver: document.getElementById('bkDriver')?.value,
            biokinieticTable: document.getElementById('bkBiokinieticTable')?.value,
            productionTable: document.getElementById('bkProductionTable')?.value,
            qualificationColumn: document.getElementById('bkQualificationColumn')?.value,
            surnameColumn: document.getElementById('bkSurnameColumn')?.value
        });
        hideSpinner();
        if (data.success) {
            document.getElementById('bkSqlText').value = data.sql;
            document.querySelector('[data-tab="sql"]')?.click();
        } else {
            setAlert(document.getElementById('bkAnalysisPane'), 'error', data.error || 'SQL generation failed');
        }
    } catch (err) {
        hideSpinner();
        setAlert(document.getElementById('bkAnalysisPane'), 'error', err.message);
    }
});

document.getElementById('bkSaveWorkspaceBtn')?.addEventListener('click', async function() {
    const clientId = parseInt(document.getElementById('bkClientId')?.value || '0');
    if (!clientId) return setAlert(document.getElementById('bkWorkspaceInfo'), 'error', 'Select an engagement');

    showSpinner('Saving workspace...');
    try {
        await postJson('/Biokinetic/SaveWorkspace', {
            clientId,
            server: document.getElementById('bkServer')?.value?.trim(),
            database: document.getElementById('bkDatabase')?.value,
            driver: document.getElementById('bkDriver')?.value,
            biokinieticTable: document.getElementById('bkBiokinieticTable')?.value,
            productionTable: document.getElementById('bkProductionTable')?.value,
            qualificationColumn: document.getElementById('bkQualificationColumn')?.value,
            surnameColumn: document.getElementById('bkSurnameColumn')?.value
        });
        hideSpinner();
        setAlert(document.getElementById('bkWorkspaceInfo'), 'success', 'Workspace saved successfully');
    } catch (err) {
        hideSpinner();
        setAlert(document.getElementById('bkWorkspaceInfo'), 'error', err.message);
    }
});

document.getElementById('bkClientId')?.addEventListener('change', async function() {
    if (!this.value) return;
    const data = await postJson('/Biokinetic/GetWorkspaceState', { clientId: parseInt(this.value) });
    if (data.success && data.workspace) {
        const ws = data.workspace;
        document.getElementById('bkBiokinieticTable').value = ws.biokinieticTable || '';
        document.getElementById('bkProductionTable').value = ws.productionTable || '';
        document.getElementById('bkQualificationColumn').value = ws.qualificationColumn || '';
        document.getElementById('bkSurnameColumn').value = ws.surnameColumn || '';
        document.getElementById('bkServer').value = ws.server || '';
        document.getElementById('bkDatabase').value = ws.database || '';
        if (ws.summary) {
            document.getElementById('bkWorkspaceRunState').textContent = ws.summary.status || '-';
            document.getElementById('bkWorkspaceStatusLabel').textContent = ws.summary.status || '-';
        }
    }
});
</script>
