@using HemisAudit.Models
@using HemisAudit.ViewModels
@{
    ViewData["Title"] = "Rule 71 - Radiography Module";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var clients = ViewBag.Clients as List<Client> ?? new List<Client>();
    var selectedClientId = (int)(ViewBag.ClientId ?? 0);
    var currentSystemRole = ViewBag.CurrentSystemRole as string ?? "";
    var isResultsOnlyRole =
        string.Equals(currentSystemRole, "Manager", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Director", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Trainee", StringComparison.OrdinalIgnoreCase);
    var moduleNavigation = ViewBag.ModuleNavigation as ModuleSequenceNavigationViewModel;
}

@if (isResultsOnlyRole)
{
    <style>
        #rgApp > .accordion-stack,
        #rgApp > .action-bar { display: none !important; }
    </style>
}

<div id="rgApp" class="rule-page-shell">
    @if (moduleNavigation != null)
    {
        @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
    }

    <div class="engagement-selector">
        <label>Engagement</label>
        <select id="rgClientId" onchange="rgHandleClientChange(this.value)">
            <option value="0">Select engagement (results saved here)</option>
            @foreach (var c in clients)
            {
                <option value="@c.Id" selected="@(c.Id == selectedClientId ? "selected" : null)">@c.Name - @c.FiscalYear</option>
            }
        </select>
        <small>Radiography validates QUALIFICATION values from the Radiography table against Clinical Production and confirms Surname matching.</small>
    </div>

    <div class="rule-header">
        <div class="rule-header__icon">RG</div>
        <div>
            <h1 class="rule-header__title">HEMIS RULE 71: Radiography Qualification &amp; Surname Validation</h1>
            <p class="rule-header__sub">Cross-table validation | QUALIFICATION lookup | Surname confirmation | 100% population test</p>
        </div>
        <div class="rule-header__badge" id="rgStatusBadge" style="display:none"></div>
    </div>

    <div class="accordion-stack">

        <div class="accordion-item" id="rg-acc-connection">
            <button class="accordion-toggle" onclick="rgToggle('connection')">
                <span class="acc-icon">DB</span>
                <span>Database Connection</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="rg-body-connection">
                <div class="form-grid">
                    <div class="field-group">
                        <label>Server Name</label>
                        <input type="text" id="rgServer" placeholder="e.g. MYSERVER or MYSERVER\INSTANCE" />
                    </div>
                    <div class="field-group">
                        <label>Driver</label>
                        <select id="rgDriver">
                            <option value="ODBC Driver 17 for SQL Server">ODBC Driver 17 for SQL Server</option>
                            <option value="ODBC Driver 18 for SQL Server">ODBC Driver 18 for SQL Server</option>
                            <option value="SQL Server">SQL Server</option>
                        </select>
                    </div>
                    <div class="field-group" id="rgDbFieldGroup" style="display:none">
                        <label>Database</label>
                        <select id="rgDatabase">
                            <option value="">Select database</option>
                        </select>
                    </div>
                </div>
                <button class="btn btn-primary" onclick="rgConnect()">Connect</button>
                <div class="status-output" id="rgConnectionStatus"></div>
            </div>
        </div>

        <div class="accordion-item" id="rg-acc-tables">
            <button class="accordion-toggle" onclick="rgToggle('tables')">
                <span class="acc-icon">TB</span>
                <span>Table Configuration</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="rg-body-tables" style="display:none">
                <div class="info-box info-box--blue">
                    <strong>Radiography Module Logic:</strong> Check that each QUALIFICATION from the Radiography table exists in
                    Clinical Production. When found, confirm the Surname matches.
                    PASS = QUALIFICATION found in production; FAIL = missing.
                </div>
                <div class="form-grid">
                    <div class="field-group">
                        <label>Radiography Table <span class="auto-tag" id="rgRgAutoTag" style="display:none">auto-detected</span></label>
                        <select id="rgRgTable">
                            <option value="">Select table</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label>Clinical Production Table <span class="auto-tag" id="rgProdAutoTag" style="display:none">auto-detected</span></label>
                        <select id="rgProdTable">
                            <option value="">Select table</option>
                        </select>
                    </div>
                </div>
                <div class="status-output" id="rgTableStatus"></div>
            </div>
        </div>

        <div class="accordion-item" id="rg-acc-columns">
            <button class="accordion-toggle" onclick="rgToggle('columns')">
                <span class="acc-icon">CL</span>
                <span>Column Configuration</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="rg-body-columns" style="display:none">
                <div class="info-box info-box--dark">
                    <strong>Column Selection:</strong> Choose the <code>QUALIFICATION</code> column (used for matching across both tables)
                    and the <code>Surname</code> column (confirmed when QUALIFICATION is found in production).
                </div>
                <div class="form-grid">
                    <div class="field-group">
                        <label>QUALIFICATION Column <span class="auto-tag" id="rgQualAutoTag" style="display:none">auto-detected</span></label>
                        <select id="rgQualCol" onchange="rgColChanged()">
                            <option value="">Select column</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label>Surname Column <span class="auto-tag" id="rgSurnameAutoTag" style="display:none">auto-detected</span></label>
                        <select id="rgSurnameCol" onchange="rgColChanged()">
                            <option value="">Select column</option>
                        </select>
                    </div>
                </div>
                <div style="margin-top:10px">
                    <button class="btn btn-secondary" onclick="rgAutoDetect()">Auto-Detect Columns</button>
                </div>
                <div id="rgColumnPreview" class="validation-preview" style="display:none;margin-top:12px"></div>
            </div>
        </div>

    </div>

    <div class="workspace-signoff-card">
        <div class="workspace-signoff-card__header">
            <div>
                <div class="workspace-signoff-card__title">Saved Workspace</div>
                <div class="workspace-signoff-card__subtitle">The last saved Rule 71 connection, configuration, results, and signoffs reload here automatically.</div>
            </div>
            <div id="rgWorkspaceRunState" class="badge badge--neutral badge--sm">No saved run loaded</div>
        </div>
        <div id="rgWorkspaceInfo" class="alert alert--info">
            Select an engagement to load the last saved Rule 71 workspace.
        </div>
        <div class="workspace-signoff-grid">
            <div class="field-group">
                <label id="rgSignoffLabel">Signoff Comment</label>
                <textarea id="rgSignoffComment" placeholder="Add the final review note that confirms this validation is complete."></textarea>
            </div>
        </div>
        <div class="workspace-signoff-actions">
            <button class="btn btn-success" id="rgSaveWorkspaceBtn" onclick="rgSaveWorkspace()">Save Workspace</button>
            <button class="btn btn-primary" id="rgSignOffBtn" onclick="rgSignOff()" style="display:none">Sign Off</button>
            <button class="btn btn-warning" id="rgRemoveSignoffBtn" onclick="rgRemoveSignoff()" style="display:none">Remove Signoff</button>
            <button class="btn btn-secondary" id="rgDownloadExcelBtn" onclick="rgDownloadExcel()" style="display:none">Download Excel</button>
            <button class="btn btn-secondary" id="rgDownloadSqlBtn" onclick="rgDownloadSql()" style="display:none">Download SQL</button>
        </div>
    </div>

    <div class="action-bar">
        <button class="btn btn-info" id="rgVerifyBtn" onclick="rgVerify()">Verify Tables</button>
        <button class="btn btn-success" id="rgRunBtn" onclick="rgRun()">Run Validation</button>
        <button class="btn btn-primary" id="rgSqlBtn" onclick="rgGenerateSql()">Generate SQL</button>
    </div>

    <div class="results-panel">
        <div class="results-tabs">
            <button class="tab-btn active" type="button" data-tab="validation" onclick="rgTab('validation')">Validation Results</button>
            <button class="tab-btn" type="button" data-tab="exceptions" onclick="rgTab('exceptions')">Exceptions</button>
            <button class="tab-btn" type="button" data-tab="sql" onclick="rgTab('sql')">SQL Code</button>
        </div>
        <div class="tab-pane active" id="rg-tab-validation">
            <div id="rgValidationContent" class="empty-state"><p>Run validation to see results here.</p></div>
        </div>
        <div class="tab-pane" id="rg-tab-exceptions">
            <div id="rgExceptionsContent" class="empty-state"><p>No exceptions data yet. Run validation first.</p></div>
        </div>
        <div class="tab-pane" id="rg-tab-sql">
            <div id="rgSqlContent" class="empty-state"><p>Click "Generate SQL" or run validation to generate the SQL script.</p></div>
        </div>
    </div>
</div>

<script>
const rgRole = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(currentSystemRole));
const rgPreviewLimit = 10;
const rg = {
    server: '', database: '', driver: 'ODBC Driver 17 for SQL Server',
    rgTable: '', prodTable: '',
    qualCol: '', surnameCol: '',
    clientId: parseInt(document.getElementById('rgClientId')?.value || '0') || 0,
    runId: null, result: null,
    view: { filter: 'ALL', page: 1, pageSize: rgPreviewLimit },
    engRole: '', status: '', signedOff: false, workspaceSaved: false,
    daSignoff: false, resultsVisible: false, dirty: false, hydrating: false,
    editAccepted: false, rgCols: [], prodCols: []
};

function rgToggle(name) {
    const body = document.getElementById(`rg-body-${name}`);
    const chevron = document.querySelector(`#rg-acc-${name} .acc-chevron`);
    if (!body) return;
    const open = body.style.display !== 'none';
    body.style.display = open ? 'none' : 'block';
    if (chevron) chevron.textContent = open ? 'v' : '^';
}

function rgTab(name) {
    document.querySelectorAll('#rgApp .tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('#rgApp .tab-pane').forEach(p => p.classList.remove('active'));
    document.querySelector(`#rgApp [data-tab="${name}"]`)?.classList.add('active');
    document.getElementById(`rg-tab-${name}`)?.classList.add('active');
}

function rgSetAlert(elId, type, msg) {
    const el = document.getElementById(elId);
    if (el) el.innerHTML = `<div class="alert alert--${type}">${msg}</div>`;
}

function rgEsc(v) {
    return String(v ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

async function rgPost(url, data) {
    return await window.fetchJsonWithProgress(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    });
}

async function rgGet(url) {
    return await window.fetchJsonWithProgress(url, { method: 'GET' });
}

function rgFillSelect(sel, items, preferred) {
    if (!sel) return;
    sel.innerHTML = '<option value="">Select table</option>';
    (items || []).forEach(v => sel.appendChild(new Option(v, v)));
    if (preferred && items.includes(preferred)) sel.value = preferred;
}

function rgFillColSelect(sel, cols, preferred) {
    if (!sel) return;
    sel.innerHTML = '<option value="">Select column</option>';
    (cols || []).forEach(c => sel.appendChild(new Option(c, c)));
    const match = preferred ? (cols || []).find(c => c.toLowerCase() === preferred.toLowerCase()) : null;
    if (match) sel.value = match;
    else if (cols?.length) sel.value = cols[0];
}

async function rgConnect(opts = {}) {
    rg.server = document.getElementById('rgServer').value.trim();
    rg.driver = document.getElementById('rgDriver').value;
    if (!rg.server) { rgSetAlert('rgConnectionStatus', 'error', 'Enter a server name.'); return null; }

    const result = await rgPost('/Radiography/GetDatabases', { server: rg.server, driver: rg.driver });
    if (!result.success) { rgSetAlert('rgConnectionStatus', 'error', `Error: ${rgEsc(result.error)}`); return null; }

    const dbSel = document.getElementById('rgDatabase');
    dbSel.innerHTML = '<option value="">Select database</option>';
    (result.databases || []).forEach(db => dbSel.appendChild(new Option(db, db)));
    document.getElementById('rgDbFieldGroup').style.display = 'block';

    if (opts.preferredDatabase && (result.databases || []).includes(opts.preferredDatabase)) {
        dbSel.value = opts.preferredDatabase;
        rg.database = opts.preferredDatabase;
    }

    rgSetAlert('rgConnectionStatus', 'success', opts.statusMessage || `Connected. Found ${result.databases?.length || 0} database(s). Select one below.`);
    return result;
}

async function rgLoadTables(opts = {}) {
    rg.database = document.getElementById('rgDatabase').value;
    if (!rg.database) return null;

    const result = await rgPost('/Radiography/GetTables', { server: rg.server, database: rg.database, driver: rg.driver });
    if (!result.success) { rgSetAlert('rgConnectionStatus', 'error', `Error: ${rgEsc(result.error)}`); return null; }

    rgSetAlert('rgConnectionStatus', 'success', `Connected to <strong>${rgEsc(rg.database)}</strong>. Found ${result.tables?.length || 0} tables.`);

    rgFillSelect(document.getElementById('rgRgTable'), result.tables || [], opts.preferredRg || result.autoRadiographyTable || '');
    rgFillSelect(document.getElementById('rgProdTable'), result.tables || [], opts.preferredProd || result.autoProductionTable || '');

    rg.rgTable = document.getElementById('rgRgTable').value;
    rg.prodTable = document.getElementById('rgProdTable').value;

    document.getElementById('rgRgAutoTag').style.display = rg.rgTable && rg.rgTable === result.autoRadiographyTable ? 'inline' : 'none';
    document.getElementById('rgProdAutoTag').style.display = rg.prodTable && rg.prodTable === result.autoProductionTable ? 'inline' : 'none';

    document.getElementById('rg-body-tables').style.display = 'block';
    document.querySelector('#rg-acc-tables .acc-chevron').textContent = '^';

    if (rg.rgTable || rg.prodTable)
        await rgLoadColumns(opts);

    return result;
}

async function rgLoadColumns(opts = {}) {
    const rgTable = document.getElementById('rgRgTable').value;
    const prodTable = document.getElementById('rgProdTable').value;
    if (!rg.server || !rg.database) return;

    const rgColsRes = rgTable ? await rgPost('/Radiography/GetColumns', {
        server: rg.server, database: rg.database, driver: rg.driver, tableName: rgTable
    }) : { success: false, columns: [] };

    const prodColsRes = prodTable ? await rgPost('/Radiography/GetColumns', {
        server: rg.server, database: rg.database, driver: rg.driver, tableName: prodTable
    }) : { success: false, columns: [] };

    rg.rgCols = rgColsRes.columns || [];
    rg.prodCols = prodColsRes.columns || [];

    const allCols = [...new Set([...rg.rgCols, ...rg.prodCols])];

    rgFillColSelect(document.getElementById('rgQualCol'), allCols, opts.preferredQual || 'QUALIFICATION');
    rgFillColSelect(document.getElementById('rgSurnameCol'), allCols, opts.preferredSurname || 'Surname');

    rg.qualCol = document.getElementById('rgQualCol').value;
    rg.surnameCol = document.getElementById('rgSurnameCol').value;

    const qualAuto = allCols.find(c => c.toLowerCase() === 'qualification');
    const surnameAuto = allCols.find(c => c.toLowerCase() === 'surname');
    document.getElementById('rgQualAutoTag').style.display = qualAuto ? 'inline' : 'none';
    document.getElementById('rgSurnameAutoTag').style.display = surnameAuto ? 'inline' : 'none';

    document.getElementById('rg-body-columns').style.display = 'block';
    document.querySelector('#rg-acc-columns .acc-chevron').textContent = '^';

    rgUpdatePreview();
}

function rgColChanged() {
    rg.qualCol = document.getElementById('rgQualCol').value;
    rg.surnameCol = document.getElementById('rgSurnameCol').value;
    rgUpdatePreview();
}

function rgUpdatePreview() {
    rg.qualCol = document.getElementById('rgQualCol').value;
    rg.surnameCol = document.getElementById('rgSurnameCol').value;
    rg.rgTable = document.getElementById('rgRgTable').value;
    rg.prodTable = document.getElementById('rgProdTable').value;

    const preview = document.getElementById('rgColumnPreview');
    if (!rg.qualCol || !rg.surnameCol || !rg.rgTable || !rg.prodTable) {
        preview.style.display = 'none';
        return;
    }
    preview.style.display = 'block';
    preview.innerHTML = `
        <div class="preview-inner">
            <strong>Validation Logic:</strong><br>
            PASS: <code>[${rgEsc(rg.rgTable)}].[${rgEsc(rg.qualCol)}]</code> found in <code>[${rgEsc(rg.prodTable)}].[${rgEsc(rg.qualCol)}]</code><br>
            Then confirm <code>[${rgEsc(rg.rgTable)}].[${rgEsc(rg.surnameCol)}]</code> matches <code>[${rgEsc(rg.prodTable)}].[${rgEsc(rg.surnameCol)}]</code><br>
            FAIL: QUALIFICATION not found in production table.
        </div>`;
}

async function rgAutoDetect() {
    const rgTable = document.getElementById('rgRgTable').value;
    const prodTable = document.getElementById('rgProdTable').value;

    if (!rgTable && !prodTable) {
        rgSetAlert('rgColumnPreview', 'warning', 'Select at least one table first.');
        document.getElementById('rgColumnPreview').style.display = 'block';
        return;
    }

    await rgLoadColumns({ preferredQual: 'QUALIFICATION', preferredSurname: 'Surname' });
    rgSetAlert('rgColumnPreview', 'success', 'Column detection complete. You can change the selected columns using the dropdowns above.');
    document.getElementById('rgColumnPreview').style.display = 'block';
}

async function rgVerify() {
    if (!rgValidate()) return;
    const result = await rgPost('/Radiography/VerifyTables', rgBuildRequest());
    if (!result.success) { rgSetAlert('rgTableStatus', 'error', `Error: ${rgEsc(result.error)}`); return; }
    rgSetAlert('rgTableStatus', 'success',
        `<strong>Verification Complete</strong><br>
        ${rgEsc(rg.rgTable)}: <strong>${(result.radiographyRecordCount || 0).toLocaleString()}</strong> records<br>
        ${rgEsc(rg.prodTable)}: <strong>${(result.productionRecordCount || 0).toLocaleString()}</strong> records<br>
        QUALIFICATION matches: <strong class="${result.matchedCount > 0 ? 'text-success' : 'text-danger'}">${(result.matchedCount || 0).toLocaleString()}</strong> |
        Missing: <strong class="${result.missingCount > 0 ? 'text-danger' : 'text-success'}">${(result.missingCount || 0).toLocaleString()}</strong>`);
    document.getElementById('rg-body-tables').style.display = 'block';
}

async function rgRun() {
    if (rgRole !== 'DataAnalyst') { rgSetWsInfo('Only the assigned data analyst can run Rule 71.', 'error'); return; }
    if (!rgValidate()) return;

    const result = await rgPost('/Radiography/RunValidation', {
        ...rgBuildRequest(), clientId: rg.clientId
    });

    if (!result.success) {
        const el = document.getElementById('rgValidationContent');
        el.classList.remove('empty-state');
        el.innerHTML = `<div class="alert alert--error">Error: ${rgEsc(result.error)}</div>`;
        rgTab('validation');
        return;
    }

    rgApplyResult(result);
}

function rgApplyResult(result, opts = {}) {
    rg.result = result;
    rg.view = { filter: 'ALL', page: 1, pageSize: rgPreviewLimit };
    if (!opts.fromWorkspace) rg.runId = result.savedRunId || rg.runId;
    rg.signedOff = opts.fromWorkspace ? !!rg.signedOff : false;
    rg.daSignoff = opts.fromWorkspace ? !!rg.daSignoff : false;
    if (!opts.fromWorkspace) rg.editAccepted = false;
    rg.dirty = false;

    rgUpdateBadge(result.status);
    rgRenderValidation(result);
    rgRenderExceptions(result);
    if (opts.switchToValidation !== false) rgTab('validation');
    rgRenderState();
}

function rgUpdateBadge(status) {
    const b = document.getElementById('rgStatusBadge');
    if (!b) return;
    if (!status) { b.style.display = 'none'; return; }
    b.style.display = 'inline-block';
    b.className = `rule-header__badge ${status === 'PASS' ? 'badge--pass' : 'badge--fail'}`;
    b.textContent = status.toUpperCase();
}

function rgFilterRows(rows, f) {
    return f === 'PASS' || f === 'FAIL' ? rows.filter(r => r.status === f) : rows;
}

function rgRenderValidation(r) {
    const rate = parseFloat(r.exceptionRate);
    const rateColor = rate > 5 ? '#C62828' : rate > 1 ? '#E65100' : '#2E7D32';
    const allRows = r.reviewRows || [];
    const filtered = rgFilterRows(allRows, rg.view.filter);
    const pageSize = rgPreviewLimit;
    const totalPages = Math.max(1, Math.ceil(filtered.length / pageSize));
    const page = Math.min(Math.max(rg.view.page || 1, 1), totalPages);
    rg.view.page = page;
    const start = (page - 1) * pageSize;
    const pageRows = filtered.slice(start, start + pageSize);

    const rowsHtml = pageRows.length === 0
        ? `<div class="alert alert--info">No rows match the selected filter.</div>`
        : `<div class="results-table-shell"><div class="table-wrapper">
            <table class="data-table">
                <thead><tr><th>#</th><th>Result</th><th>RG QUAL</th><th>RG Surname</th><th>Production QUAL</th><th>Production Surname</th></tr></thead>
                <tbody>${pageRows.map((row, i) => `
                    <tr class="${i % 2 === 0 ? 'row-even' : 'row-odd'}">
                        <td>${start + i + 1}</td>
                        <td><span class="badge badge--${row.status === 'PASS' ? 'pass' : 'fail'}">${rgEsc(row.status)}</span></td>
                        <td>${rgEsc(row.radiographyQualification)}</td>
                        <td>${rgEsc(row.radiographySurname)}</td>
                        <td>${rgEsc(row.productionQualification)}</td>
                        <td>${rgEsc(row.productionSurname)}</td>
                    </tr>`).join('')}
                </tbody>
            </table></div>
            <div class="table-footer">${filtered.length.toLocaleString()} row(s) after filter. Showing ${start + 1}–${start + pageRows.length}.</div>
        </div>`;

    document.getElementById('rgValidationContent').classList.remove('empty-state');
    document.getElementById('rgValidationContent').innerHTML = `
        <div class="stats-grid">
            <div class="stat-card"><div class="stat-card__label">Records Validated</div><div class="stat-card__value">${r.totalValidated.toLocaleString()}</div></div>
            <div class="stat-card stat-card--pass"><div class="stat-card__label">PASS</div><div class="stat-card__value">${r.passCount.toLocaleString()}</div></div>
            <div class="stat-card stat-card--fail"><div class="stat-card__label">FAIL</div><div class="stat-card__value">${r.failCount.toLocaleString()}</div></div>
            <div class="stat-card"><div class="stat-card__label">Exception Rate</div><div class="stat-card__value" style="color:${rateColor}">${rate.toFixed(2)}%</div></div>
        </div>
        <div class="overall-status ${r.status === 'PASS' ? 'status--pass' : 'status--fail'}">
            ${r.status === 'PASS'
                ? 'VALIDATION PASSED — All Radiography QUALIFICATION codes found in Clinical Production'
                : `VALIDATION FAILED — ${r.failCount.toLocaleString()} QUALIFICATION code(s) missing from Clinical Production`}
        </div>
        ${r.warning ? `<div class="alert alert--warning" style="margin-top:10px">${rgEsc(r.warning)}</div>` : ''}
        <div class="results-table-panel" style="margin-top:16px">
            <div class="panel-title-row">
                <h4>Validation Rows</h4>
                <span class="panel-title-badge">${filtered.length.toLocaleString()} rows (preview)</span>
            </div>
            <div class="validation-toolbar">
                <div class="validation-toolbar__group">
                    <label>Filter</label>
                    <select onchange="rgSetFilter(this.value)">
                        <option value="ALL" ${rg.view.filter === 'ALL' ? 'selected' : ''}>All</option>
                        <option value="PASS" ${rg.view.filter === 'PASS' ? 'selected' : ''}>PASS</option>
                        <option value="FAIL" ${rg.view.filter === 'FAIL' ? 'selected' : ''}>FAIL</option>
                    </select>
                </div>
                <div class="validation-pager">
                    <button class="btn btn-sm btn-info" onclick="rgSetPage(-1)" ${page <= 1 ? 'disabled' : ''}>Prev</button>
                    <span class="validation-pager__status">Page ${page} of ${totalPages}</span>
                    <button class="btn btn-sm btn-info" onclick="rgSetPage(1)" ${page >= totalPages ? 'disabled' : ''}>Next</button>
                </div>
            </div>
            ${rowsHtml}
        </div>`;
}

function rgRenderExceptions(r) {
    const el = document.getElementById('rgExceptionsContent');
    el.classList.remove('empty-state');
    if (r.failCount === 0) {
        el.innerHTML = '<div class="alert alert--success">No exceptions — all QUALIFICATION codes found in Clinical Production.</div>';
        return;
    }
    const rows = (r.reviewRows || []).filter(x => x.status === 'FAIL').slice(0, 50);
    el.innerHTML = `
        <div class="results-table-shell"><div class="table-wrapper">
        <table class="data-table">
            <thead><tr><th>#</th><th>RG QUAL</th><th>RG Surname</th><th>Result</th></tr></thead>
            <tbody>${rows.map((row, i) => `
                <tr class="${i % 2 === 0 ? 'row-even' : 'row-odd'}">
                    <td>${i + 1}</td>
                    <td><strong>${rgEsc(row.radiographyQualification)}</strong></td>
                    <td>${rgEsc(row.radiographySurname)}</td>
                    <td><span class="badge badge--fail">FAIL</span></td>
                </tr>`).join('')}
            </tbody>
        </table></div>
        <div class="table-footer">${r.failCount.toLocaleString()} exception(s) total. Showing up to 50.</div>
        </div>`;
}

function rgSetFilter(f) {
    rg.view.filter = f; rg.view.page = 1;
    if (rg.result) rgRenderValidation(rg.result);
}

function rgSetPage(delta) {
    if (!rg.result) return;
    rg.view.page = Math.max(1, (rg.view.page || 1) + delta);
    rgRenderValidation(rg.result);
}

async function rgGenerateSql() {
    if (rgRole !== 'DataAnalyst') { rgSetWsInfo('Only the assigned data analyst can generate SQL.', 'error'); return; }
    if (!rgValidate()) return;
    const result = await rgPost('/Radiography/GenerateSql', {
        ...rgBuildRequest(), clientId: rg.clientId
    });
    if (!result.success) return;
    const el = document.getElementById('rgSqlContent');
    el.classList.remove('empty-state');
    el.innerHTML = `
        <div class="sql-toolbar">
            <button class="btn btn-sm btn-primary" onclick="rgCopy('rgSqlCode')">Copy</button>
        </div>
        <div class="sql-panel"><pre id="rgSqlCode" class="sql-block">${rgEsc(result.sql)}</pre></div>`;
    rgTab('sql');
}

function rgCopy(id) {
    const text = document.getElementById(id)?.textContent || '';
    navigator.clipboard.writeText(text).then(() => alert('Copied to clipboard!'));
}

async function rgSaveWorkspace() {
    if (rgRole !== 'DataAnalyst') { rgSetWsInfo('Only the assigned data analyst can save this workspace.', 'error'); return; }
    if (!rg.clientId) { rgSetWsInfo('Select an engagement first.', 'error'); return; }
    const result = await rgPost('/Radiography/SaveWorkspace', { ...rgBuildRequest(), clientId: rg.clientId });
    if (!result.success) { rgSetWsInfo(`Error: ${rgEsc(result.error || 'Failed to save.')}`, 'error'); return; }
    rg.workspaceSaved = true;
    rg.dirty = false;
    rgSetWsInfo(result.message || 'Workspace saved successfully.', 'success');
    rgRenderState();
}

async function rgSignOff() {
    if (!rg.runId) { rgSetWsInfo('Run validation first so the workspace can be signed off.', 'warning'); return; }
    if (!rg.workspaceSaved) { rgSetWsInfo('Save the workspace first before signing off.', 'warning'); return; }
    const result = await rgPost('/Radiography/AddSignoff', {
        runId: rg.runId,
        comment: document.getElementById('rgSignoffComment').value.trim()
    });
    if (!result.success) { rgSetWsInfo(`Error: ${rgEsc(result.error || 'Failed to sign off.')}`, 'error'); return; }
    rg.signedOff = true;
    rgSetWsInfo('Workspace signoff saved. Other assigned users can now review this signed run.', 'success');
    rgRenderState();
}

async function rgRemoveSignoff() {
    if (!rg.runId) { rgSetWsInfo('No active run to remove signoff from.', 'warning'); return; }
    const result = await rgPost('/Radiography/RemoveSignoff', { runId: rg.runId, comment: '' });
    if (!result.success) { rgSetWsInfo(`Error: ${rgEsc(result.error || 'Failed to remove signoff.')}`, 'error'); return; }
    rg.signedOff = false;
    rgSetWsInfo('Signoff removed.', 'warning');
    rgRenderState();
}

async function rgDownloadExcel() {
    if (!rg.result) { rgSetWsInfo('Run validation first before downloading.', 'warning'); return; }
    await rgPostFile('/Radiography/DownloadExcel', rg.result, 'Rule71_Radiography.xlsx');
}

async function rgDownloadSql() {
    if (!rg.clientId) { rgSetWsInfo('Select an engagement first.', 'warning'); return; }
    const result = await rgPost('/Radiography/DownloadSql', rgBuildRequest());
    if (!result.success) { rgSetWsInfo(`Error: ${rgEsc(result.error || 'Failed.')}`, 'error'); return; }
    const blob = new Blob([result.sql], { type: 'text/plain' });
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
    a.download = 'Rule71_Radiography.sql'; a.click(); URL.revokeObjectURL(a.href);
}

async function rgPostFile(url, body, filename) {
    const token = document.querySelector('[name=__RequestVerificationToken]')?.value || '';
    const resp = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token }, body: JSON.stringify(body) });
    if (!resp.ok) { rgSetWsInfo('Download failed.', 'error'); return; }
    const blob = await resp.blob();
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
    a.download = filename; a.click(); URL.revokeObjectURL(a.href);
}

function rgSetWsRunState(text, type) {
    const el = document.getElementById('rgWorkspaceRunState');
    if (!el) return;
    el.className = `badge badge--${type} badge--sm`;
    el.textContent = text;
}

function rgSetWsInfo(msg, type) {
    const el = document.getElementById('rgWorkspaceInfo');
    if (!el) return;
    el.className = `alert alert--${type}`;
    el.innerHTML = msg;
}

function rgRenderState() {
    const canEdit = rgRole === 'DataAnalyst';
    const saveBtn = document.getElementById('rgSaveWorkspaceBtn');
    const signBtn = document.getElementById('rgSignOffBtn');
    const removeBtn = document.getElementById('rgRemoveSignoffBtn');
    const verifyBtn = document.getElementById('rgVerifyBtn');
    const runBtn = document.getElementById('rgRunBtn');
    const sqlBtn = document.getElementById('rgSqlBtn');
    if (saveBtn) saveBtn.disabled = !canEdit || rg.signedOff;
    if (signBtn) {
        signBtn.style.display = canEdit && rg.runId ? 'inline-flex' : 'none';
        signBtn.disabled = !rg.workspaceSaved || rg.dirty || rg.signedOff;
        signBtn.textContent = rg.signedOff ? 'Signed Off' : 'Sign Off';
    }
    if (removeBtn) removeBtn.style.display = canEdit && rg.signedOff ? 'inline-flex' : 'none';
    const dlExcelBtn = document.getElementById('rgDownloadExcelBtn');
    const dlSqlBtn = document.getElementById('rgDownloadSqlBtn');
    if (dlExcelBtn) dlExcelBtn.style.display = rg.result ? 'inline-flex' : 'none';
    if (dlSqlBtn) dlSqlBtn.style.display = rg.clientId ? 'inline-flex' : 'none';
    if (verifyBtn) verifyBtn.disabled = rg.signedOff;
    if (runBtn) runBtn.disabled = rg.signedOff;
    if (sqlBtn) sqlBtn.disabled = rg.signedOff;

    if (!rg.clientId) { rgSetWsRunState('No engagement selected', 'neutral'); rgSetWsInfo('Select an engagement to load the last saved Rule 71 workspace.', 'info'); return; }
    if (!rg.runId) { rgSetWsRunState('No saved run loaded', 'neutral'); rgSetWsInfo(canEdit ? 'No saved workspace yet. Connect, configure, run validation, then save.' : 'No saved workspace for this engagement yet.', 'info'); return; }
    if (rg.dirty) { rgSetWsRunState(`Run #${rg.runId} — unsaved changes`, 'warning'); rgSetWsInfo(`Saved run <strong>#${rg.runId}</strong> is loaded but the current screen has unsaved changes.`, 'warning'); return; }
    if (rg.signedOff) { rgSetWsRunState(`Run #${rg.runId} signed off`, 'success'); rgSetWsInfo(`Saved run <strong>#${rg.runId}</strong> is signed off and available for review.`, 'success'); return; }
    rgSetWsRunState(`Run #${rg.runId} saved`, 'info');
    rgSetWsInfo(canEdit ? `Saved run <strong>#${rg.runId}</strong> is loaded. Save and sign off to make results visible to other roles.` : `Saved run <strong>#${rg.runId}</strong> is awaiting analyst signoff.`, 'info');
}

function rgReset(clearClient) {
    rg.server = ''; rg.database = ''; rg.driver = 'ODBC Driver 17 for SQL Server';
    rg.rgTable = ''; rg.prodTable = ''; rg.qualCol = ''; rg.surnameCol = '';
    rg.runId = null; rg.result = null;
    rg.view = { filter: 'ALL', page: 1, pageSize: rgPreviewLimit };
    rg.engRole = ''; rg.status = ''; rg.signedOff = false; rg.workspaceSaved = false;
    rg.daSignoff = false; rg.resultsVisible = false; rg.dirty = false;
    rg.editAccepted = false; rg.rgCols = []; rg.prodCols = [];
    if (clearClient) rg.clientId = 0;

    ['rgServer','rgSignoffComment'].forEach(id => { const el = document.getElementById(id); if (el) el.value = ''; });
    document.getElementById('rgDriver').value = 'ODBC Driver 17 for SQL Server';
    document.getElementById('rgDatabase').innerHTML = '<option value="">Select database</option>';
    document.getElementById('rgDbFieldGroup').style.display = 'none';
    ['rgRgTable','rgProdTable','rgQualCol','rgSurnameCol'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.innerHTML = '<option value="">Select table</option>';
    });
    ['rgRgAutoTag','rgProdAutoTag','rgQualAutoTag','rgSurnameAutoTag'].forEach(id => {
        const el = document.getElementById(id); if (el) el.style.display = 'none';
    });
    document.getElementById('rgColumnPreview').style.display = 'none';
    document.getElementById('rgConnectionStatus').innerHTML = '';
    document.getElementById('rgTableStatus').innerHTML = '';
    document.getElementById('rgValidationContent').className = 'empty-state';
    document.getElementById('rgValidationContent').innerHTML = '<p>Run validation to see results here.</p>';
    document.getElementById('rgExceptionsContent').className = 'empty-state';
    document.getElementById('rgExceptionsContent').innerHTML = '<p>No exceptions data yet. Run validation first.</p>';
    document.getElementById('rgSqlContent').className = 'empty-state';
    document.getElementById('rgSqlContent').innerHTML = '<p>Click "Generate SQL" or run validation to generate the SQL script.</p>';
    rgUpdateBadge('');
    rgRenderState();
}

async function rgHandleClientChange(value) {
    rg.clientId = parseInt(value || '0') || 0;
    rgReset();
    if (!rg.clientId) return;
    await rgLoadWorkspace();
}

async function rgLoadWorkspace() {
    if (!rg.clientId) { rgRenderState(); return; }
    try {
        const result = await rgGet(`/Radiography/GetWorkspaceState?clientId=${rg.clientId}`);
        if (!result.success) { rgSetWsInfo(`Error: ${rgEsc(result.error || 'Failed to load workspace.')}`, 'error'); return; }
        if (!result.hasWorkspace || !result.workspace) { rgRenderState(); return; }
        await rgHydrate(result.workspace);
    } catch (err) { rgSetWsInfo(`Error: ${rgEsc(err?.message || 'Failed.')}`, 'error'); }
}

async function rgHydrate(ws) {
    rg.hydrating = true;
    try {
        rg.runId = ws.lastRunId || null;
        rg.engRole = ws.currentUserEngagementRole || '';
        rg.status = ws.currentStatus || '';
        rg.signedOff = !!ws.currentUserHasSignedOff;
        rg.workspaceSaved = !!ws.isWorkspaceSaved;
        rg.daSignoff = !!ws.hasDataAnalystSignoff;
        rg.resultsVisible = !!ws.resultsVisible;

        document.getElementById('rgServer').value = ws.server || '';
        document.getElementById('rgDriver').value = ws.driver || 'ODBC Driver 17 for SQL Server';
        document.getElementById('rgSignoffComment').value = ws.currentUserSignoffComment || '';
        rg.server = ws.server || '';
        rg.driver = ws.driver || 'ODBC Driver 17 for SQL Server';

        if (ws.summary && rg.resultsVisible) rgApplyResult(ws.summary, { switchToValidation: false, fromWorkspace: true });
        else if (ws.summary) rgUpdateBadge(ws.summary.status || '');

        if (ws.server) {
            await rgConnect({ preferredDatabase: ws.database || '', silent: true,
                statusMessage: ws.database ? `Connected to <strong>${rgEsc(ws.database)}</strong>. Restored from saved workspace.` : 'Reconnected.' });
        }
        if (ws.database) {
            await rgLoadTables({
                preferredRg: ws.radiographyTable || ws.rgTable || 'Radiography',
                preferredProd: ws.productionTable || 'Clinical_Production',
                preferredQual: ws.qualificationColumn || 'QUALIFICATION',
                preferredSurname: ws.surnameColumn || 'Surname',
                silent: true
            });
        }
    } finally {
        rg.hydrating = false;
        rg.dirty = false;
        rgRenderState();
    }
}

function rgValidate() {
    const missing = [];
    if (!rg.clientId) missing.push('engagement');
    if (!rg.server) missing.push('server');
    if (!rg.database) missing.push('database');
    if (!rg.rgTable) missing.push('Radiography table');
    if (!rg.prodTable) missing.push('Production table');
    if (!rg.qualCol) missing.push('QUALIFICATION column');
    if (!rg.surnameCol) missing.push('Surname column');
    if (missing.length) {
        rgSetWsInfo(`Please select: ${missing.join(', ')}.`, 'warning');
        return false;
    }
    return true;
}

function rgBuildRequest() {
    return {
        server: rg.server,
        database: rg.database,
        driver: rg.driver,
        radiographyTable: document.getElementById('rgRgTable').value || rg.rgTable,
        productionTable: document.getElementById('rgProdTable').value || rg.prodTable,
        qualificationColumn: document.getElementById('rgQualCol').value || rg.qualCol,
        surnameColumn: document.getElementById('rgSurnameCol').value || rg.surnameCol
    };
}

document.addEventListener('DOMContentLoaded', async () => {
    document.getElementById('rgServer').addEventListener('input', () => { rg.server = document.getElementById('rgServer').value.trim(); });
    document.getElementById('rgDriver').addEventListener('change', () => { rg.driver = document.getElementById('rgDriver').value; });

    document.getElementById('rgDatabase').addEventListener('change', async e => {
        rg.database = e.target.value;
        if (rg.database) await rgLoadTables();
    });

    document.getElementById('rgRgTable').addEventListener('change', async e => {
        rg.rgTable = e.target.value;
        if (rg.rgTable) {
            const r = await rgPost('/Radiography/GetColumns', { server: rg.server, database: rg.database, driver: rg.driver, tableName: rg.rgTable });
            rg.rgCols = r.columns || [];
            const allCols = [...new Set([...rg.rgCols, ...rg.prodCols])];
            rgFillColSelect(document.getElementById('rgQualCol'), allCols, 'QUALIFICATION');
            rgFillColSelect(document.getElementById('rgSurnameCol'), allCols, 'Surname');
            rg.qualCol = document.getElementById('rgQualCol').value;
            rg.surnameCol = document.getElementById('rgSurnameCol').value;
            document.getElementById('rg-body-columns').style.display = 'block';
            document.querySelector('#rg-acc-columns .acc-chevron').textContent = '^';
            rgUpdatePreview();
        }
    });

    document.getElementById('rgProdTable').addEventListener('change', async e => {
        rg.prodTable = e.target.value;
        if (rg.prodTable) {
            const r = await rgPost('/Radiography/GetColumns', { server: rg.server, database: rg.database, driver: rg.driver, tableName: rg.prodTable });
            rg.prodCols = r.columns || [];
            const allCols = [...new Set([...rg.rgCols, ...rg.prodCols])];
            rgFillColSelect(document.getElementById('rgQualCol'), allCols, 'QUALIFICATION');
            rgFillColSelect(document.getElementById('rgSurnameCol'), allCols, 'Surname');
            rg.qualCol = document.getElementById('rgQualCol').value;
            rg.surnameCol = document.getElementById('rgSurnameCol').value;
            rgUpdatePreview();
        }
    });

    document.getElementById('rgQualCol').addEventListener('change', rgColChanged);
    document.getElementById('rgSurnameCol').addEventListener('change', rgColChanged);

    rgRenderState();
    if (rg.clientId > 0) await rgLoadWorkspace();
});
</script>
