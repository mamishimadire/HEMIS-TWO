@using HemisAudit.Models
@using HemisAudit.ViewModels
@{
    ViewData["Title"] = "Rule 69 - ClinicalTech Module";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var clients = ViewBag.Clients as List<Client> ?? new List<Client>();
    var selectedClientId = (int)(ViewBag.ClientId ?? 0);
    var currentSystemRole = ViewBag.CurrentSystemRole as string ?? "";
    var isResultsOnlyRole =
        string.Equals(currentSystemRole, "Manager", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Director", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(currentSystemRole, "Trainee", StringComparison.OrdinalIgnoreCase);
    var moduleNavigation = ViewBag.ModuleNavigation as ModuleSequenceNavigationViewModel;
}

@if (isResultsOnlyRole)
{
    <style>
        #ctApp > .accordion-stack,
        #ctApp > .action-bar { display: none !important; }
    </style>
}

<div id="ctApp" class="rule-page-shell">
    @if (moduleNavigation != null)
    {
        @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
    }

    <div class="engagement-selector">
        <label>Engagement</label>
        <select id="ctClientId" onchange="ctHandleClientChange(this.value)">
            <option value="0">Select engagement (results saved here)</option>
            @foreach (var c in clients)
            {
                <option value="@c.Id" selected="@(c.Id == selectedClientId ? "selected" : null)">@c.Name - @c.FiscalYear</option>
            }
        </select>
        <small>ClinicalTech validates QUALIFICATION values from the ClinicalTech table against Clinical Production and confirms Surname matching.</small>
    </div>

    <div class="rule-header">
        <div class="rule-header__icon">CT</div>
        <div>
            <h1 class="rule-header__title">HEMIS RULE 69: ClinicalTech Qualification &amp; Surname Validation</h1>
            <p class="rule-header__sub">Cross-table validation | QUALIFICATION lookup | Surname confirmation | 100% population test</p>
        </div>
        <div class="rule-header__badge" id="ctStatusBadge" style="display:none"></div>
    </div>

    <div class="accordion-stack">

        <div class="accordion-item" id="ct-acc-connection">
            <button class="accordion-toggle" onclick="ctToggle('connection')">
                <span class="acc-icon">DB</span>
                <span>Database Connection</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="ct-body-connection">
                <div class="form-grid">
                    <div class="field-group">
                        <label>Server Name</label>
                        <input type="text" id="ctServer" placeholder="e.g. MYSERVER or MYSERVER\INSTANCE" />
                    </div>
                    <div class="field-group">
                        <label>Driver</label>
                        <select id="ctDriver">
                            <option value="ODBC Driver 17 for SQL Server">ODBC Driver 17 for SQL Server</option>
                            <option value="ODBC Driver 18 for SQL Server">ODBC Driver 18 for SQL Server</option>
                            <option value="SQL Server">SQL Server</option>
                        </select>
                    </div>
                    <div class="field-group" id="ctDbFieldGroup" style="display:none">
                        <label>Database</label>
                        <select id="ctDatabase">
                            <option value="">Select database</option>
                        </select>
                    </div>
                </div>
                <button class="btn btn-primary" onclick="ctConnect()">Connect</button>
                <div class="status-output" id="ctConnectionStatus"></div>
            </div>
        </div>

        <div class="accordion-item" id="ct-acc-tables">
            <button class="accordion-toggle" onclick="ctToggle('tables')">
                <span class="acc-icon">TB</span>
                <span>Table Configuration</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="ct-body-tables" style="display:none">
                <div class="info-box info-box--blue">
                    <strong>ClinicalTech Module Logic:</strong> Check that each QUALIFICATION from the ClinicalTech table exists in
                    Clinical Production. When found, confirm the Surname matches.
                    PASS = QUALIFICATION found in production; FAIL = missing.
                </div>
                <div class="form-grid">
                    <div class="field-group">
                        <label>ClinicalTech Table <span class="auto-tag" id="ctCtAutoTag" style="display:none">auto-detected</span></label>
                        <select id="ctCtTable">
                            <option value="">Select table</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label>Clinical Production Table <span class="auto-tag" id="ctProdAutoTag" style="display:none">auto-detected</span></label>
                        <select id="ctProdTable">
                            <option value="">Select table</option>
                        </select>
                    </div>
                </div>
                <div class="status-output" id="ctTableStatus"></div>
            </div>
        </div>

        <div class="accordion-item" id="ct-acc-columns">
            <button class="accordion-toggle" onclick="ctToggle('columns')">
                <span class="acc-icon">CL</span>
                <span>Column Configuration</span>
                <span class="acc-chevron">v</span>
            </button>
            <div class="accordion-body" id="ct-body-columns" style="display:none">
                <div class="info-box info-box--dark">
                    <strong>Column Selection:</strong> Choose the <code>QUALIFICATION</code> column (used for matching across both tables)
                    and the <code>Surname</code> column (confirmed when QUALIFICATION is found in production).
                </div>
                <div class="form-grid">
                    <div class="field-group">
                        <label>QUALIFICATION Column <span class="auto-tag" id="ctQualAutoTag" style="display:none">auto-detected</span></label>
                        <select id="ctQualCol" onchange="ctColChanged()">
                            <option value="">Select column</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label>Surname Column <span class="auto-tag" id="ctSurnameAutoTag" style="display:none">auto-detected</span></label>
                        <select id="ctSurnameCol" onchange="ctColChanged()">
                            <option value="">Select column</option>
                        </select>
                    </div>
                </div>
                <div style="margin-top:10px">
                    <button class="btn btn-secondary" onclick="ctAutoDetect()">Auto-Detect Columns</button>
                </div>
                <div id="ctColumnPreview" class="validation-preview" style="display:none;margin-top:12px"></div>
            </div>
        </div>

    </div>

    <div class="workspace-signoff-card">
        <div class="workspace-signoff-card__header">
            <div>
                <div class="workspace-signoff-card__title">Saved Workspace</div>
                <div class="workspace-signoff-card__subtitle">The last saved Rule 69 connection, configuration, results, and signoffs reload here automatically.</div>
            </div>
            <div id="ctWorkspaceRunState" class="badge badge--neutral badge--sm">No saved run loaded</div>
        </div>
        <div id="ctWorkspaceInfo" class="alert alert--info">
            Select an engagement to load the last saved Rule 69 workspace.
        </div>
        <div class="workspace-signoff-grid">
            <div class="field-group">
                <label id="ctSignoffLabel">Signoff Comment</label>
                <textarea id="ctSignoffComment" placeholder="Add the final review note that confirms this validation is complete."></textarea>
            </div>
        </div>
        <div class="workspace-signoff-actions">
            <button class="btn btn-success" id="ctSaveWorkspaceBtn" onclick="ctSaveWorkspace()">Save Workspace</button>
            <button class="btn btn-primary" id="ctSignOffBtn" onclick="ctSignOff()" style="display:none">Sign Off</button>
            <button class="btn btn-warning" id="ctRemoveSignoffBtn" onclick="ctRemoveSignoff()" style="display:none">Remove Signoff</button>
            <button class="btn btn-secondary" id="ctDownloadExcelBtn" onclick="ctDownloadExcel()" style="display:none">Download Excel</button>
            <button class="btn btn-secondary" id="ctDownloadSqlBtn" onclick="ctDownloadSql()" style="display:none">Download SQL</button>
        </div>
    </div>

    <div class="action-bar">
        <button class="btn btn-info" id="ctVerifyBtn" onclick="ctVerify()">Verify Tables</button>
        <button class="btn btn-success" id="ctRunBtn" onclick="ctRun()">Run Validation</button>
        <button class="btn btn-primary" id="ctSqlBtn" onclick="ctGenerateSql()">Generate SQL</button>
    </div>

    <div class="results-panel">
        <div class="results-tabs">
            <button class="tab-btn active" type="button" data-tab="validation" onclick="ctTab('validation')">Validation Results</button>
            <button class="tab-btn" type="button" data-tab="exceptions" onclick="ctTab('exceptions')">Exceptions</button>
            <button class="tab-btn" type="button" data-tab="sql" onclick="ctTab('sql')">SQL Code</button>
        </div>
        <div class="tab-pane active" id="ct-tab-validation">
            <div id="ctValidationContent" class="empty-state"><p>Run validation to see results here.</p></div>
        </div>
        <div class="tab-pane" id="ct-tab-exceptions">
            <div id="ctExceptionsContent" class="empty-state"><p>No exceptions data yet. Run validation first.</p></div>
        </div>
        <div class="tab-pane" id="ct-tab-sql">
            <div id="ctSqlContent" class="empty-state"><p>Click "Generate SQL" or run validation to generate the SQL script.</p></div>
        </div>
    </div>
</div>

<script>
const ctRole = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(currentSystemRole));
const ctPreviewLimit = 10;
const ct = {
    server: '', database: '', driver: 'ODBC Driver 17 for SQL Server',
    ctTable: '', prodTable: '',
    qualCol: '', surnameCol: '',
    clientId: parseInt(document.getElementById('ctClientId')?.value || '0') || 0,
    runId: null, result: null,
    view: { filter: 'ALL', page: 1, pageSize: ctPreviewLimit },
    engRole: '', status: '', signedOff: false, workspaceSaved: false,
    daSignoff: false, resultsVisible: false, dirty: false, hydrating: false,
    editAccepted: false, ctCols: [], prodCols: []
};

// ── Utilities ──────────────────────────────────────────────────────────────

function ctToggle(name) {
    const body = document.getElementById(`ct-body-${name}`);
    const chevron = document.querySelector(`#ct-acc-${name} .acc-chevron`);
    if (!body) return;
    const open = body.style.display !== 'none';
    body.style.display = open ? 'none' : 'block';
    if (chevron) chevron.textContent = open ? 'v' : '^';
}

function ctTab(name) {
    document.querySelectorAll('#ctApp .tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('#ctApp .tab-pane').forEach(p => p.classList.remove('active'));
    document.querySelector(`#ctApp [data-tab="${name}"]`)?.classList.add('active');
    document.getElementById(`ct-tab-${name}`)?.classList.add('active');
}

function ctSetAlert(elId, type, msg) {
    const el = document.getElementById(elId);
    if (el) el.innerHTML = `<div class="alert alert--${type}">${msg}</div>`;
}

function ctEsc(v) {
    return String(v ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

async function ctPost(url, data) {
    return await window.fetchJsonWithProgress(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    });
}

async function ctGet(url) {
    return await window.fetchJsonWithProgress(url, { method: 'GET' });
}

function ctFillSelect(sel, items, preferred) {
    if (!sel) return;
    sel.innerHTML = '<option value="">Select table</option>';
    (items || []).forEach(v => sel.appendChild(new Option(v, v)));
    if (preferred && items.includes(preferred)) sel.value = preferred;
}

function ctFillColSelect(sel, cols, preferred) {
    if (!sel) return;
    sel.innerHTML = '<option value="">Select column</option>';
    (cols || []).forEach(c => sel.appendChild(new Option(c, c)));
    const match = preferred ? (cols || []).find(c => c.toLowerCase() === preferred.toLowerCase()) : null;
    if (match) sel.value = match;
    else if (cols?.length) sel.value = cols[0];
}

// ── Connection ─────────────────────────────────────────────────────────────

async function ctConnect(opts = {}) {
    ct.server = document.getElementById('ctServer').value.trim();
    ct.driver = document.getElementById('ctDriver').value;
    if (!ct.server) { ctSetAlert('ctConnectionStatus', 'error', 'Enter a server name.'); return null; }

    const result = await ctPost('/ClinicalTech/GetDatabases', { server: ct.server, driver: ct.driver });
    if (!result.success) { ctSetAlert('ctConnectionStatus', 'error', `Error: ${ctEsc(result.error)}`); return null; }

    const dbSel = document.getElementById('ctDatabase');
    dbSel.innerHTML = '<option value="">Select database</option>';
    (result.databases || []).forEach(db => dbSel.appendChild(new Option(db, db)));
    document.getElementById('ctDbFieldGroup').style.display = 'block';

    if (opts.preferredDatabase && (result.databases || []).includes(opts.preferredDatabase)) {
        dbSel.value = opts.preferredDatabase;
        ct.database = opts.preferredDatabase;
    }

    ctSetAlert('ctConnectionStatus', 'success', opts.statusMessage || `Connected. Found ${result.databases?.length || 0} database(s). Select one below.`);
    return result;
}

async function ctLoadTables(opts = {}) {
    ct.database = document.getElementById('ctDatabase').value;
    if (!ct.database) return null;

    const result = await ctPost('/ClinicalTech/GetTables', { server: ct.server, database: ct.database, driver: ct.driver });
    if (!result.success) { ctSetAlert('ctConnectionStatus', 'error', `Error: ${ctEsc(result.error)}`); return null; }

    ctSetAlert('ctConnectionStatus', 'success', `Connected to <strong>${ctEsc(ct.database)}</strong>. Found ${result.tables?.length || 0} tables.`);

    ctFillSelect(document.getElementById('ctCtTable'), result.tables || [], opts.preferredCt || result.autoClinicaltechTable || '');
    ctFillSelect(document.getElementById('ctProdTable'), result.tables || [], opts.preferredProd || result.autoProductionTable || '');

    ct.ctTable = document.getElementById('ctCtTable').value;
    ct.prodTable = document.getElementById('ctProdTable').value;

    document.getElementById('ctCtAutoTag').style.display = ct.ctTable && ct.ctTable === result.autoClinicaltechTable ? 'inline' : 'none';
    document.getElementById('ctProdAutoTag').style.display = ct.prodTable && ct.prodTable === result.autoProductionTable ? 'inline' : 'none';

    document.getElementById('ct-body-tables').style.display = 'block';
    document.querySelector('#ct-acc-tables .acc-chevron').textContent = '^';

    if (ct.ctTable || ct.prodTable)
        await ctLoadColumns(opts);

    return result;
}

async function ctLoadColumns(opts = {}) {
    const ctTable = document.getElementById('ctCtTable').value;
    const prodTable = document.getElementById('ctProdTable').value;
    if (!ct.server || !ct.database) return;

    const ctColsRes = ctTable ? await ctPost('/ClinicalTech/GetColumns', {
        server: ct.server, database: ct.database, driver: ct.driver, tableName: ctTable
    }) : { success: false, columns: [] };

    const prodColsRes = prodTable ? await ctPost('/ClinicalTech/GetColumns', {
        server: ct.server, database: ct.database, driver: ct.driver, tableName: prodTable
    }) : { success: false, columns: [] };

    ct.ctCols = ctColsRes.columns || [];
    ct.prodCols = prodColsRes.columns || [];

    const allCols = [...new Set([...ct.ctCols, ...ct.prodCols])];

    ctFillColSelect(document.getElementById('ctQualCol'), allCols, opts.preferredQual || 'QUALIFICATION');
    ctFillColSelect(document.getElementById('ctSurnameCol'), allCols, opts.preferredSurname || 'Surname');

    ct.qualCol = document.getElementById('ctQualCol').value;
    ct.surnameCol = document.getElementById('ctSurnameCol').value;

    const qualAuto = allCols.find(c => c.toLowerCase() === 'qualification');
    const surnameAuto = allCols.find(c => c.toLowerCase() === 'surname');
    document.getElementById('ctQualAutoTag').style.display = qualAuto ? 'inline' : 'none';
    document.getElementById('ctSurnameAutoTag').style.display = surnameAuto ? 'inline' : 'none';

    document.getElementById('ct-body-columns').style.display = 'block';
    document.querySelector('#ct-acc-columns .acc-chevron').textContent = '^';

    ctUpdatePreview();
}

function ctColChanged() {
    ct.qualCol = document.getElementById('ctQualCol').value;
    ct.surnameCol = document.getElementById('ctSurnameCol').value;
    ctUpdatePreview();
}

function ctUpdatePreview() {
    ct.qualCol = document.getElementById('ctQualCol').value;
    ct.surnameCol = document.getElementById('ctSurnameCol').value;
    ct.ctTable = document.getElementById('ctCtTable').value;
    ct.prodTable = document.getElementById('ctProdTable').value;

    const preview = document.getElementById('ctColumnPreview');
    if (!ct.qualCol || !ct.surnameCol || !ct.ctTable || !ct.prodTable) {
        preview.style.display = 'none';
        return;
    }
    preview.style.display = 'block';
    preview.innerHTML = `
        <div class="preview-inner">
            <strong>Validation Logic:</strong><br>
            PASS: <code>[${ctEsc(ct.ctTable)}].[${ctEsc(ct.qualCol)}]</code> found in <code>[${ctEsc(ct.prodTable)}].[${ctEsc(ct.qualCol)}]</code><br>
            Then confirm <code>[${ctEsc(ct.ctTable)}].[${ctEsc(ct.surnameCol)}]</code> matches <code>[${ctEsc(ct.prodTable)}].[${ctEsc(ct.surnameCol)}]</code><br>
            FAIL: QUALIFICATION not found in production table.
        </div>`;
}

async function ctAutoDetect() {
    const ctTable = document.getElementById('ctCtTable').value;
    const prodTable = document.getElementById('ctProdTable').value;

    if (!ctTable && !prodTable) {
        ctSetAlert('ctColumnPreview', 'warning', 'Select at least one table first.');
        document.getElementById('ctColumnPreview').style.display = 'block';
        return;
    }

    await ctLoadColumns({ preferredQual: 'QUALIFICATION', preferredSurname: 'Surname' });
    ctSetAlert('ctColumnPreview', 'success', 'Column detection complete. You can change the selected columns using the dropdowns above.');
    document.getElementById('ctColumnPreview').style.display = 'block';
}

// ── Verify / Run ───────────────────────────────────────────────────────────

async function ctVerify() {
    if (!ctValidate()) return;
    const result = await ctPost('/ClinicalTech/VerifyTables', ctBuildRequest());
    if (!result.success) { ctSetAlert('ctTableStatus', 'error', `Error: ${ctEsc(result.error)}`); return; }
    ctSetAlert('ctTableStatus', 'success',
        `<strong>Verification Complete</strong><br>
        ${ctEsc(ct.ctTable)}: <strong>${(result.clinicaltechRecordCount || 0).toLocaleString()}</strong> records<br>
        ${ctEsc(ct.prodTable)}: <strong>${(result.productionRecordCount || 0).toLocaleString()}</strong> records<br>
        QUALIFICATION matches: <strong class="${result.matchedCount > 0 ? 'text-success' : 'text-danger'}">${(result.matchedCount || 0).toLocaleString()}</strong> |
        Missing: <strong class="${result.missingCount > 0 ? 'text-danger' : 'text-success'}">${(result.missingCount || 0).toLocaleString()}</strong>`);
    document.getElementById('ct-body-tables').style.display = 'block';
}

async function ctRun() {
    if (ctRole !== 'DataAnalyst') { ctSetWsInfo('Only the assigned data analyst can run Rule 69.', 'error'); return; }
    if (!ctValidate()) return;

    const result = await ctPost('/ClinicalTech/RunValidation', {
        ...ctBuildRequest(), clientId: ct.clientId
    });

    if (!result.success) {
        const el = document.getElementById('ctValidationContent');
        el.classList.remove('empty-state');
        el.innerHTML = `<div class="alert alert--error">Error: ${ctEsc(result.error)}</div>`;
        ctTab('validation');
        return;
    }

    ctApplyResult(result);
}

function ctApplyResult(result, opts = {}) {
    ct.result = result;
    ct.view = { filter: 'ALL', page: 1, pageSize: ctPreviewLimit };
    if (!opts.fromWorkspace) ct.runId = result.savedRunId || ct.runId;
    ct.signedOff = opts.fromWorkspace ? !!ct.signedOff : false;
    ct.daSignoff = opts.fromWorkspace ? !!ct.daSignoff : false;
    if (!opts.fromWorkspace) ct.editAccepted = false;
    ct.dirty = false;

    ctUpdateBadge(result.status);
    ctRenderValidation(result);
    ctRenderExceptions(result);
    if (opts.switchToValidation !== false) ctTab('validation');
    ctRenderState();
}

// ── Render helpers ─────────────────────────────────────────────────────────

function ctUpdateBadge(status) {
    const b = document.getElementById('ctStatusBadge');
    if (!b) return;
    if (!status) { b.style.display = 'none'; return; }
    b.style.display = 'inline-block';
    b.className = `rule-header__badge ${status === 'PASS' ? 'badge--pass' : 'badge--fail'}`;
    b.textContent = status.toUpperCase();
}

function ctFilterRows(rows, f) {
    return f === 'PASS' || f === 'FAIL' ? rows.filter(r => r.status === f) : rows;
}

function ctRenderValidation(r) {
    const rate = parseFloat(r.exceptionRate);
    const rateColor = rate > 5 ? '#C62828' : rate > 1 ? '#E65100' : '#2E7D32';
    const allRows = r.reviewRows || [];
    const filtered = ctFilterRows(allRows, ct.view.filter);
    const pageSize = ctPreviewLimit;
    const totalPages = Math.max(1, Math.ceil(filtered.length / pageSize));
    const page = Math.min(Math.max(ct.view.page || 1, 1), totalPages);
    ct.view.page = page;
    const start = (page - 1) * pageSize;
    const pageRows = filtered.slice(start, start + pageSize);

    const rowsHtml = pageRows.length === 0
        ? `<div class="alert alert--info">No rows match the selected filter.</div>`
        : `<div class="results-table-shell"><div class="table-wrapper">
            <table class="data-table">
                <thead><tr><th>#</th><th>Result</th><th>CT QUAL</th><th>CT Surname</th><th>Production QUAL</th><th>Production Surname</th></tr></thead>
                <tbody>${pageRows.map((row, i) => `
                    <tr class="${i % 2 === 0 ? 'row-even' : 'row-odd'}">
                        <td>${start + i + 1}</td>
                        <td><span class="badge badge--${row.status === 'PASS' ? 'pass' : 'fail'}">${ctEsc(row.status)}</span></td>
                        <td>${ctEsc(row.clinicaltechQualification)}</td>
                        <td>${ctEsc(row.clinicaltechSurname)}</td>
                        <td>${ctEsc(row.productionQualification)}</td>
                        <td>${ctEsc(row.productionSurname)}</td>
                    </tr>`).join('')}
                </tbody>
            </table></div>
            <div class="table-footer">${filtered.length.toLocaleString()} row(s) after filter. Showing ${start + 1}–${start + pageRows.length}.</div>
        </div>`;

    document.getElementById('ctValidationContent').classList.remove('empty-state');
    document.getElementById('ctValidationContent').innerHTML = `
        <div class="stats-grid">
            <div class="stat-card"><div class="stat-card__label">Records Validated</div><div class="stat-card__value">${r.totalValidated.toLocaleString()}</div></div>
            <div class="stat-card stat-card--pass"><div class="stat-card__label">PASS</div><div class="stat-card__value">${r.passCount.toLocaleString()}</div></div>
            <div class="stat-card stat-card--fail"><div class="stat-card__label">FAIL</div><div class="stat-card__value">${r.failCount.toLocaleString()}</div></div>
            <div class="stat-card"><div class="stat-card__label">Exception Rate</div><div class="stat-card__value" style="color:${rateColor}">${rate.toFixed(2)}%</div></div>
        </div>
        <div class="overall-status ${r.status === 'PASS' ? 'status--pass' : 'status--fail'}">
            ${r.status === 'PASS'
                ? 'VALIDATION PASSED — All ClinicalTech QUALIFICATION codes found in Clinical Production'
                : `VALIDATION FAILED — ${r.failCount.toLocaleString()} QUALIFICATION code(s) missing from Clinical Production`}
        </div>
        ${r.warning ? `<div class="alert alert--warning" style="margin-top:10px">${ctEsc(r.warning)}</div>` : ''}
        <div class="results-table-panel" style="margin-top:16px">
            <div class="panel-title-row">
                <h4>Validation Rows</h4>
                <span class="panel-title-badge">${filtered.length.toLocaleString()} rows (preview)</span>
            </div>
            <div class="validation-toolbar">
                <div class="validation-toolbar__group">
                    <label>Filter</label>
                    <select onchange="ctSetFilter(this.value)">
                        <option value="ALL" ${ct.view.filter === 'ALL' ? 'selected' : ''}>All</option>
                        <option value="PASS" ${ct.view.filter === 'PASS' ? 'selected' : ''}>PASS</option>
                        <option value="FAIL" ${ct.view.filter === 'FAIL' ? 'selected' : ''}>FAIL</option>
                    </select>
                </div>
                <div class="validation-pager">
                    <button class="btn btn-sm btn-info" onclick="ctSetPage(-1)" ${page <= 1 ? 'disabled' : ''}>Prev</button>
                    <span class="validation-pager__status">Page ${page} of ${totalPages}</span>
                    <button class="btn btn-sm btn-info" onclick="ctSetPage(1)" ${page >= totalPages ? 'disabled' : ''}>Next</button>
                </div>
            </div>
            ${rowsHtml}
        </div>`;
}

function ctRenderExceptions(r) {
    const el = document.getElementById('ctExceptionsContent');
    el.classList.remove('empty-state');
    if (r.failCount === 0) {
        el.innerHTML = '<div class="alert alert--success">No exceptions — all QUALIFICATION codes found in Clinical Production.</div>';
        return;
    }
    const rows = (r.reviewRows || []).filter(x => x.status === 'FAIL').slice(0, 50);
    el.innerHTML = `
        <div class="results-table-shell"><div class="table-wrapper">
        <table class="data-table">
            <thead><tr><th>#</th><th>CT QUAL</th><th>CT Surname</th><th>Result</th></tr></thead>
            <tbody>${rows.map((row, i) => `
                <tr class="${i % 2 === 0 ? 'row-even' : 'row-odd'}">
                    <td>${i + 1}</td>
                    <td><strong>${ctEsc(row.clinicaltechQualification)}</strong></td>
                    <td>${ctEsc(row.clinicaltechSurname)}</td>
                    <td><span class="badge badge--fail">FAIL</span></td>
                </tr>`).join('')}
            </tbody>
        </table></div>
        <div class="table-footer">${r.failCount.toLocaleString()} exception(s) total. Showing up to 50.</div>
        </div>`;
}

function ctSetFilter(f) {
    ct.view.filter = f; ct.view.page = 1;
    if (ct.result) ctRenderValidation(ct.result);
}

function ctSetPage(delta) {
    if (!ct.result) return;
    ct.view.page = Math.max(1, (ct.view.page || 1) + delta);
    ctRenderValidation(ct.result);
}

// ── SQL ────────────────────────────────────────────────────────────────────

async function ctGenerateSql() {
    if (ctRole !== 'DataAnalyst') { ctSetWsInfo('Only the assigned data analyst can generate SQL.', 'error'); return; }
    if (!ctValidate()) return;
    const result = await ctPost('/ClinicalTech/GenerateSql', {
        ...ctBuildRequest(), clientId: ct.clientId
    });
    if (!result.success) return;
    const el = document.getElementById('ctSqlContent');
    el.classList.remove('empty-state');
    el.innerHTML = `
        <div class="sql-toolbar">
            <button class="btn btn-sm btn-primary" onclick="ctCopy('ctSqlCode')">Copy</button>
        </div>
        <div class="sql-panel"><pre id="ctSqlCode" class="sql-block">${ctEsc(result.sql)}</pre></div>`;
    ctTab('sql');
}

function ctCopy(id) {
    const text = document.getElementById(id)?.textContent || '';
    navigator.clipboard.writeText(text).then(() => alert('Copied to clipboard!'));
}

// ── Workspace save / signoff ───────────────────────────────────────────────

async function ctSaveWorkspace() {
    if (ctRole !== 'DataAnalyst') { ctSetWsInfo('Only the assigned data analyst can save this workspace.', 'error'); return; }
    if (!ct.clientId) { ctSetWsInfo('Select an engagement first.', 'error'); return; }
    const result = await ctPost('/ClinicalTech/SaveWorkspace', { ...ctBuildRequest(), clientId: ct.clientId });
    if (!result.success) { ctSetWsInfo(`Error: ${ctEsc(result.error || 'Failed to save.')}`, 'error'); return; }
    ct.workspaceSaved = true;
    ct.dirty = false;
    ctSetWsInfo(result.message || 'Workspace saved successfully.', 'success');
    ctRenderState();
}

async function ctSignOff() {
    if (!ct.runId) { ctSetWsInfo('Run validation first so the workspace can be signed off.', 'warning'); return; }
    if (!ct.workspaceSaved) { ctSetWsInfo('Save the workspace first before signing off.', 'warning'); return; }
    const result = await ctPost('/ClinicalTech/AddSignoff', {
        runId: ct.runId,
        comment: document.getElementById('ctSignoffComment').value.trim()
    });
    if (!result.success) { ctSetWsInfo(`Error: ${ctEsc(result.error || 'Failed to sign off.')}`, 'error'); return; }
    ct.signedOff = true;
    ctSetWsInfo('Workspace signoff saved. Other assigned users can now review this signed run.', 'success');
    ctRenderState();
}

async function ctRemoveSignoff() {
    if (!ct.runId) { ctSetWsInfo('No active run to remove signoff from.', 'warning'); return; }
    const result = await ctPost('/ClinicalTech/RemoveSignoff', { runId: ct.runId, comment: '' });
    if (!result.success) { ctSetWsInfo(`Error: ${ctEsc(result.error || 'Failed to remove signoff.')}`, 'error'); return; }
    ct.signedOff = false;
    ctSetWsInfo('Signoff removed.', 'warning');
    ctRenderState();
}

async function ctDownloadExcel() {
    if (!ct.result) { ctSetWsInfo('Run validation first before downloading.', 'warning'); return; }
    await ctPostFile('/ClinicalTech/DownloadExcel', ct.result, 'Rule69_ClinicalTech.xlsx');
}

async function ctDownloadSql() {
    if (!ct.clientId) { ctSetWsInfo('Select an engagement first.', 'warning'); return; }
    const result = await ctPost('/ClinicalTech/DownloadSql', ctBuildRequest());
    if (!result.success) { ctSetWsInfo(`Error: ${ctEsc(result.error || 'Failed.')}`, 'error'); return; }
    const blob = new Blob([result.sql], { type: 'text/plain' });
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
    a.download = 'Rule69_ClinicalTech.sql'; a.click(); URL.revokeObjectURL(a.href);
}

async function ctPostFile(url, body, filename) {
    const token = document.querySelector('[name=__RequestVerificationToken]')?.value || '';
    const resp = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token }, body: JSON.stringify(body) });
    if (!resp.ok) { ctSetWsInfo('Download failed.', 'error'); return; }
    const blob = await resp.blob();
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
    a.download = filename; a.click(); URL.revokeObjectURL(a.href);
}

// ── State management ───────────────────────────────────────────────────────

function ctSetWsRunState(text, type) {
    const el = document.getElementById('ctWorkspaceRunState');
    if (!el) return;
    el.className = `badge badge--${type} badge--sm`;
    el.textContent = text;
}

function ctSetWsInfo(msg, type) {
    const el = document.getElementById('ctWorkspaceInfo');
    if (!el) return;
    el.className = `alert alert--${type}`;
    el.innerHTML = msg;
}

function ctRenderState() {
    const canEdit = ctRole === 'DataAnalyst';
    const saveBtn = document.getElementById('ctSaveWorkspaceBtn');
    const signBtn = document.getElementById('ctSignOffBtn');
    const removeBtn = document.getElementById('ctRemoveSignoffBtn');
    const verifyBtn = document.getElementById('ctVerifyBtn');
    const runBtn = document.getElementById('ctRunBtn');
    const sqlBtn = document.getElementById('ctSqlBtn');
    if (saveBtn) saveBtn.disabled = !canEdit || ct.signedOff;
    if (signBtn) {
        signBtn.style.display = canEdit && ct.runId ? 'inline-flex' : 'none';
        signBtn.disabled = !ct.workspaceSaved || ct.dirty || ct.signedOff;
        signBtn.textContent = ct.signedOff ? 'Signed Off' : 'Sign Off';
    }
    if (removeBtn) removeBtn.style.display = canEdit && ct.signedOff ? 'inline-flex' : 'none';
    const dlExcelBtn = document.getElementById('ctDownloadExcelBtn');
    const dlSqlBtn = document.getElementById('ctDownloadSqlBtn');
    if (dlExcelBtn) dlExcelBtn.style.display = ct.result ? 'inline-flex' : 'none';
    if (dlSqlBtn) dlSqlBtn.style.display = ct.clientId ? 'inline-flex' : 'none';
    if (verifyBtn) verifyBtn.disabled = ct.signedOff;
    if (runBtn) runBtn.disabled = ct.signedOff;
    if (sqlBtn) sqlBtn.disabled = ct.signedOff;

    if (!ct.clientId) { ctSetWsRunState('No engagement selected', 'neutral'); ctSetWsInfo('Select an engagement to load the last saved Rule 69 workspace.', 'info'); return; }
    if (!ct.runId) { ctSetWsRunState('No saved run loaded', 'neutral'); ctSetWsInfo(canEdit ? 'No saved workspace yet. Connect, configure, run validation, then save.' : 'No saved workspace for this engagement yet.', 'info'); return; }
    if (ct.dirty) { ctSetWsRunState(`Run #${ct.runId} — unsaved changes`, 'warning'); ctSetWsInfo(`Saved run <strong>#${ct.runId}</strong> is loaded but the current screen has unsaved changes.`, 'warning'); return; }
    if (ct.signedOff) { ctSetWsRunState(`Run #${ct.runId} signed off`, 'success'); ctSetWsInfo(`Saved run <strong>#${ct.runId}</strong> is signed off and available for review.`, 'success'); return; }
    ctSetWsRunState(`Run #${ct.runId} saved`, 'info');
    ctSetWsInfo(canEdit ? `Saved run <strong>#${ct.runId}</strong> is loaded. Save and sign off to make results visible to other roles.` : `Saved run <strong>#${ct.runId}</strong> is awaiting analyst signoff.`, 'info');
}

function ctReset(clearClient) {
    ct.server = ''; ct.database = ''; ct.driver = 'ODBC Driver 17 for SQL Server';
    ct.ctTable = ''; ct.prodTable = ''; ct.qualCol = ''; ct.surnameCol = '';
    ct.runId = null; ct.result = null;
    ct.view = { filter: 'ALL', page: 1, pageSize: ctPreviewLimit };
    ct.engRole = ''; ct.status = ''; ct.signedOff = false; ct.workspaceSaved = false;
    ct.daSignoff = false; ct.resultsVisible = false; ct.dirty = false;
    ct.editAccepted = false; ct.ctCols = []; ct.prodCols = [];
    if (clearClient) ct.clientId = 0;

    ['ctServer','ctSignoffComment'].forEach(id => { const el = document.getElementById(id); if (el) el.value = ''; });
    document.getElementById('ctDriver').value = 'ODBC Driver 17 for SQL Server';
    document.getElementById('ctDatabase').innerHTML = '<option value="">Select database</option>';
    document.getElementById('ctDbFieldGroup').style.display = 'none';
    ['ctCtTable','ctProdTable','ctQualCol','ctSurnameCol'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.innerHTML = '<option value="">Select table</option>';
    });
    ['ctCtAutoTag','ctProdAutoTag','ctQualAutoTag','ctSurnameAutoTag'].forEach(id => {
        const el = document.getElementById(id); if (el) el.style.display = 'none';
    });
    document.getElementById('ctColumnPreview').style.display = 'none';
    document.getElementById('ctConnectionStatus').innerHTML = '';
    document.getElementById('ctTableStatus').innerHTML = '';
    document.getElementById('ctValidationContent').className = 'empty-state';
    document.getElementById('ctValidationContent').innerHTML = '<p>Run validation to see results here.</p>';
    document.getElementById('ctExceptionsContent').className = 'empty-state';
    document.getElementById('ctExceptionsContent').innerHTML = '<p>No exceptions data yet. Run validation first.</p>';
    document.getElementById('ctSqlContent').className = 'empty-state';
    document.getElementById('ctSqlContent').innerHTML = '<p>Click "Generate SQL" or run validation to generate the SQL script.</p>';
    ctUpdateBadge('');
    ctRenderState();
}

async function ctHandleClientChange(value) {
    ct.clientId = parseInt(value || '0') || 0;
    ctReset();
    if (!ct.clientId) return;
    await ctLoadWorkspace();
}

async function ctLoadWorkspace() {
    if (!ct.clientId) { ctRenderState(); return; }
    try {
        const result = await ctGet(`/ClinicalTech/GetWorkspaceState?clientId=${ct.clientId}`);
        if (!result.success) { ctSetWsInfo(`Error: ${ctEsc(result.error || 'Failed to load workspace.')}`, 'error'); return; }
        if (!result.hasWorkspace || !result.workspace) { ctRenderState(); return; }
        await ctHydrate(result.workspace);
    } catch (err) { ctSetWsInfo(`Error: ${ctEsc(err?.message || 'Failed.')}`, 'error'); }
}

async function ctHydrate(ws) {
    ct.hydrating = true;
    try {
        ct.runId = ws.lastRunId || null;
        ct.engRole = ws.currentUserEngagementRole || '';
        ct.status = ws.currentStatus || '';
        ct.signedOff = !!ws.currentUserHasSignedOff;
        ct.workspaceSaved = !!ws.isWorkspaceSaved;
        ct.daSignoff = !!ws.hasDataAnalystSignoff;
        ct.resultsVisible = !!ws.resultsVisible;

        document.getElementById('ctServer').value = ws.server || '';
        document.getElementById('ctDriver').value = ws.driver || 'ODBC Driver 17 for SQL Server';
        document.getElementById('ctSignoffComment').value = ws.currentUserSignoffComment || '';
        ct.server = ws.server || '';
        ct.driver = ws.driver || 'ODBC Driver 17 for SQL Server';

        if (ws.summary && ct.resultsVisible) ctApplyResult(ws.summary, { switchToValidation: false, fromWorkspace: true });
        else if (ws.summary) ctUpdateBadge(ws.summary.status || '');

        if (ws.server) {
            await ctConnect({ preferredDatabase: ws.database || '', silent: true,
                statusMessage: ws.database ? `Connected to <strong>${ctEsc(ws.database)}</strong>. Restored from saved workspace.` : 'Reconnected.' });
        }
        if (ws.database) {
            await ctLoadTables({
                preferredCt: ws.clinicaltechTable || ws.ctTable || 'Clinicaltech',
                preferredProd: ws.productionTable || 'Clinical_Production',
                preferredQual: ws.qualificationColumn || 'QUALIFICATION',
                preferredSurname: ws.surnameColumn || 'Surname',
                silent: true
            });
        }
    } finally {
        ct.hydrating = false;
        ct.dirty = false;
        ctRenderState();
    }
}

// ── Validation helpers ─────────────────────────────────────────────────────

function ctValidate() {
    const missing = [];
    if (!ct.clientId) missing.push('engagement');
    if (!ct.server) missing.push('server');
    if (!ct.database) missing.push('database');
    if (!ct.ctTable) missing.push('ClinicalTech table');
    if (!ct.prodTable) missing.push('Production table');
    if (!ct.qualCol) missing.push('QUALIFICATION column');
    if (!ct.surnameCol) missing.push('Surname column');
    if (missing.length) {
        ctSetWsInfo(`Please select: ${missing.join(', ')}.`, 'warning');
        return false;
    }
    return true;
}

function ctBuildRequest() {
    return {
        server: ct.server,
        database: ct.database,
        driver: ct.driver,
        clinicaltechTable: document.getElementById('ctCtTable').value || ct.ctTable,
        productionTable: document.getElementById('ctProdTable').value || ct.prodTable,
        qualificationColumn: document.getElementById('ctQualCol').value || ct.qualCol,
        surnameColumn: document.getElementById('ctSurnameCol').value || ct.surnameCol
    };
}

// ── Wire up change events ──────────────────────────────────────────────────

document.addEventListener('DOMContentLoaded', async () => {
    document.getElementById('ctServer').addEventListener('input', () => { ct.server = document.getElementById('ctServer').value.trim(); });
    document.getElementById('ctDriver').addEventListener('change', () => { ct.driver = document.getElementById('ctDriver').value; });

    document.getElementById('ctDatabase').addEventListener('change', async e => {
        ct.database = e.target.value;
        if (ct.database) await ctLoadTables();
    });

    document.getElementById('ctCtTable').addEventListener('change', async e => {
        ct.ctTable = e.target.value;
        if (ct.ctTable) {
            const r = await ctPost('/ClinicalTech/GetColumns', { server: ct.server, database: ct.database, driver: ct.driver, tableName: ct.ctTable });
            ct.ctCols = r.columns || [];
            const allCols = [...new Set([...ct.ctCols, ...ct.prodCols])];
            ctFillColSelect(document.getElementById('ctQualCol'), allCols, 'QUALIFICATION');
            ctFillColSelect(document.getElementById('ctSurnameCol'), allCols, 'Surname');
            ct.qualCol = document.getElementById('ctQualCol').value;
            ct.surnameCol = document.getElementById('ctSurnameCol').value;
            document.getElementById('ct-body-columns').style.display = 'block';
            document.querySelector('#ct-acc-columns .acc-chevron').textContent = '^';
            ctUpdatePreview();
        }
    });

    document.getElementById('ctProdTable').addEventListener('change', async e => {
        ct.prodTable = e.target.value;
        if (ct.prodTable) {
            const r = await ctPost('/ClinicalTech/GetColumns', { server: ct.server, database: ct.database, driver: ct.driver, tableName: ct.prodTable });
            ct.prodCols = r.columns || [];
            const allCols = [...new Set([...ct.ctCols, ...ct.prodCols])];
            ctFillColSelect(document.getElementById('ctQualCol'), allCols, 'QUALIFICATION');
            ctFillColSelect(document.getElementById('ctSurnameCol'), allCols, 'Surname');
            ct.qualCol = document.getElementById('ctQualCol').value;
            ct.surnameCol = document.getElementById('ctSurnameCol').value;
            ctUpdatePreview();
        }
    });

    document.getElementById('ctQualCol').addEventListener('change', ctColChanged);
    document.getElementById('ctSurnameCol').addEventListener('change', ctColChanged);

    ctRenderState();
    if (ct.clientId > 0) await ctLoadWorkspace();
});
</script>
