@model HemisAudit.ViewModels.Rule21RunReviewViewModel
@{
    ViewData["Title"] = $"Rule 21 Run {Model.RunId}";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var canDownload = ViewBag.CanDownloadSavedRun is bool a && a;
    var canManageEngagement = ViewBag.CanManageEngagement is bool b && b;
    var canOpenWorkspace = ViewBag.CanOpenWorkspace is bool c && c;
    var isArchived = ViewBag.IsArchived is bool d && d;
    var moduleNavigation = ViewBag.ModuleNavigation as HemisAudit.ViewModels.ModuleSequenceNavigationViewModel;
    var flaggedRows = Model.Summary.FlaggedRows ?? new List<HemisAudit.ViewModels.Rule21ValidationRowViewModel>();
    var clearRows = Model.Summary.ClearSampleRows ?? new List<HemisAudit.ViewModels.Rule21ValidationRowViewModel>();
    var previewRows = flaggedRows.Take(10).Concat(clearRows.Take(10)).ToList();
    var total = Model.Summary.TotalValidated;
    var flaggedCount = Model.Summary.FlaggedCount;
    var clearCount = Model.Summary.ClearCount;
    var rate = Model.Summary.ExceptionRate;
    var maxCount = Math.Max(Math.Max(flaggedCount, clearCount), 1);
    var flaggedH = Math.Max((decimal)flaggedCount / maxCount * 220m, flaggedCount > 0 ? 24m : 4m);
    var clearH = Math.Max((decimal)clearCount / maxCount * 220m, clearCount > 0 ? 24m : 4m);
    var complianceColor = rate <= 10m ? "#008000" : rate <= 30m ? "#f59e0b" : "#dc2626";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert--success" style="margin-bottom:16px">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert--error" style="margin-bottom:16px">@TempData["Error"]</div>
}
@if (moduleNavigation != null)
{
    @await Html.PartialAsync("_ModuleSequenceNav", moduleNavigation)
}

<style>
    .review-tabs { display:flex; gap:0; border-bottom:1px solid #e5e7eb; margin-bottom:24px; overflow:auto; }
    .review-tab { background:none; border:0; border-bottom:3px solid transparent; color:#334155; cursor:pointer; font:inherit; padding:14px 18px; white-space:nowrap; }
    .review-tab.is-active { border-bottom-color:#ef4444; color:#dc2626; font-weight:700; }
    .review-panel { display:none; }
    .review-panel.is-active { display:block; }
    .viz-grid { display:grid; gap:16px; grid-template-columns:repeat(auto-fit, minmax(240px, 1fr)); }
    .viz-card { background:#fff; border:1px solid #e5e7eb; border-radius:18px; padding:20px; box-shadow:0 4px 12px rgba(15,23,42,.06); }
    .code-panel { background:#0f172a; border-radius:18px; color:#e2e8f0; overflow:auto; padding:18px; }
    .code-panel pre { margin:0; white-space:pre-wrap; word-break:break-word; }
    .r21-table-wrap { overflow-x:auto; border:1px solid #e5e7eb; border-radius:12px; }
    .r21-table { width:100%; border-collapse:collapse; font-size:13px; font-family:Consolas,"Courier New",monospace; }
    .r21-table th { background:#8b0000; color:#fff; padding:8px 10px; text-align:left; white-space:nowrap; }
    .r21-table td { padding:7px 10px; border-top:1px solid #e5e7eb; white-space:nowrap; }
    .r21-table tr.is-flagged td { background:#fff3f3; }
    .r21-table tr.is-clear td { background:#f3fff3; }
    .is-flagged-text { color:#b91c1c; font-weight:700; }
    .is-clear-text { color:#0f766e; font-weight:700; }
</style>

<div class="page-header">
    <div>
        <h1>Rule 21 — First-Time Entering Students vs Non-Aligned Qualifications</h1>
        <p>@Model.EngagementName &nbsp;|&nbsp; @Model.MaconomyNumber &nbsp;|&nbsp; Run #@Model.RunId &nbsp;|&nbsp; @Model.Summary.Timestamp</p>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
        @if (canOpenWorkspace)
        {
            <a asp-action="Index" asp-route-clientId="@Model.ClientId" class="btn btn-secondary">Back to Workspace</a>
        }
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">Dashboard</a>
        <a asp-controller="Admin" asp-action="ClientDetail" asp-route-id="@Model.ClientId" asp-fragment="validation-runs-panel" class="btn btn-secondary">Validation Runs</a>
        @if (canManageEngagement)
        {
            <a asp-controller="Admin" asp-action="ClientDetail" asp-route-id="@Model.ClientId" class="btn btn-secondary">Engagement</a>
        }
    </div>
</div>

@if (isArchived)
{
    <div class="alert alert--info" style="margin-bottom:24px">This engagement is archived. The saved run is available for review and download only.</div>
}
@if (!Model.HasDataAnalystSignoff && !isArchived)
{
    <div class="alert alert--warning" style="margin-bottom:24px">The data analyst signoff is outstanding. Assigned users can still review and download this run.</div>
}

<div class="card" style="margin-bottom:24px;padding:20px">
    <h3 class="section-title" style="margin-top:0">Signoffs</h3>
    @if (Model.CanCurrentUserSignOff && !isArchived)
    {
        <form asp-action="AddSignoff" method="post" style="margin-bottom:16px">
            @Html.AntiForgeryToken()
            <input type="hidden" name="RunId" value="@Model.RunId" />
            <div class="field-group" style="margin-bottom:12px">
                <label>Comment</label>
                <textarea name="Comment" rows="3" placeholder="Add review notes" @(Model.CurrentUserHasSignedOff ? "disabled" : "")>@Model.Signoffs.FirstOrDefault(s => s.IsCurrentUser)?.Comment</textarea>
            </div>
            <button type="submit" class="btn btn-primary" @(Model.CurrentUserHasSignedOff ? "disabled" : "")>
                @(Model.CurrentUserHasSignedOff ? $"Signed Off as {Model.CurrentUserEngagementRole}" : $"Sign Off as {Model.CurrentUserEngagementRole}")
            </button>
        </form>
        @if (Model.CanCurrentUserRemoveSignoff)
        {
            <form asp-action="RemoveSignoff" method="post" style="margin-bottom:16px">
                @Html.AntiForgeryToken()
                <input type="hidden" name="runId" value="@Model.RunId" />
                <button type="submit" class="btn btn-warning" onclick="return confirm('Remove signoff?')">Remove Signoff</button>
            </form>
        }
    }
    else if (!Model.IsCurrentRun && !isArchived)
    {
        <div class="alert alert--info" style="margin-bottom:16px">History results are read-only for signoff.</div>
    }
    @if (Model.Signoffs.Any())
    {
        <table class="data-table">
            <thead><tr><th>Role</th><th>Reviewer</th><th>Comment</th><th>Signed At</th></tr></thead>
            <tbody>
                @foreach (var s in Model.Signoffs)
                {
                    <tr>
                        <td><span class="badge badge--role">@s.SignoffRole</span></td>
                        <td><strong>@s.ReviewerName</strong><br /><small style="color:#757575">@s.ReviewerEmail</small></td>
                        <td>@(string.IsNullOrWhiteSpace(s.Comment) ? "-" : s.Comment)</td>
                        <td>@s.SignedOffAt.ToString("dd MMM yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="color:#757575">No signoffs recorded yet.</div>
    }
</div>

<div class="card" style="padding:0 0 24px">
    <div class="review-tabs">
        <button type="button" class="review-tab is-active" data-review-tab="analysis">Analysis</button>
        <button type="button" class="review-tab" data-review-tab="flagged">FLAGGED (@flaggedCount.ToString("N0"))</button>
        <button type="button" class="review-tab" data-review-tab="clear">CLEAR Sample (@clearCount.ToString("N0"))</button>
        <button type="button" class="review-tab" data-review-tab="visuals">Visualizations</button>
        <button type="button" class="review-tab" data-review-tab="sql">SQL</button>
        @if (canDownload)
        {
            <button type="button" class="review-tab" data-review-tab="downloads">Downloads</button>
        }
    </div>

    <div class="review-panel is-active" data-review-panel="analysis" style="padding:24px">
        <div class="stats-grid" style="margin-bottom:24px">
            <div class="stat-card">
                <div class="stat-card__label">First-Time Entering (FTE)</div>
                <div class="stat-card__value">@total.ToString("N0")</div>
            </div>
            <div class="stat-card stat-card--fail">
                <div class="stat-card__label">FLAGGED (Non-Aligned Found)</div>
                <div class="stat-card__value">@flaggedCount.ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-card__label">CLEAR (Not Found)</div>
                <div class="stat-card__value">@clearCount.ToString("N0")</div>
            </div>
            <div class="stat-card @(rate > 10 ? "stat-card--fail" : "")">
                <div class="stat-card__label">Exception Rate</div>
                <div class="stat-card__value">@rate.ToString("F2")%</div>
            </div>
        </div>
        <div class="card" style="padding:20px">
            <h3 class="section-title" style="margin-top:0">Run Configuration</h3>
            <div class="form-grid">
                <div><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Database</div><div>@Model.Summary.Database</div></div>
                <div><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">Status</div><div><strong style="color:@(Model.Summary.Status=="PASS"?"#008000":"#b91c1c")">@Model.Summary.Status</strong></div></div>
                <div><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">STUD Table</div><div>@Model.Summary.StudTable (filter: @Model.Summary.StudFirstTimeColumn = '@Model.Summary.StudFirstTimeValue')</div></div>
                <div><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">QUAL Table</div><div>@Model.Summary.QualTable</div></div>
                <div><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">NAL Table</div><div>@Model.Summary.NalTable (category: @Model.Summary.NalCategoryColumn = '@Model.Summary.NalCategoryValue')</div></div>
                <div><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">STUD Total Records</div><div>@Model.Summary.StudTotalCount.ToString("N0")</div></div>
                <div><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">QUAL Total Records</div><div>@Model.Summary.QualTotalCount.ToString("N0")</div></div>
                <div><div style="color:#757575;font-size:12px;text-transform:uppercase;font-weight:700">NAL Category Count</div><div>@Model.Summary.NalCategoryCount.ToString("N0")</div></div>
            </div>
        </div>
    </div>

    <div class="review-panel" data-review-panel="flagged" style="padding:24px">
        @if (flaggedRows.Any())
        {
            <div class="r21-table-wrap">
                <table class="r21-table">
                    <thead>
                        <tr>
                            <th>#</th><th>STUD Qual Ref</th><th>STUD _007</th><th>FTE Value</th>
                            <th>QUAL Code</th><th>QUAL Name</th><th>NAL Qual Name</th><th>NAL Category</th><th>Result</th><th>Reason</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in flaggedRows)
                        {
                            <tr class="is-flagged">
                                <td>@row.RowNumber</td>
                                <td>@row.StudQualRef</td>
                                <td>@row.Stud007Value</td>
                                <td>@row.Stud010Value</td>
                                <td>@row.QualCodeValue</td>
                                <td>@row.QualNameValue</td>
                                <td>@(row.NalQualName ?? "")</td>
                                <td>@(row.NalCategory ?? "")</td>
                                <td class="is-flagged-text">FLAGGED</td>
                                <td>@(row.ExceptionReason ?? "")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert--success">No FLAGGED rows — all First-Time Entering students are clear of Non-Aligned qualifications.</div>
        }
    </div>

    <div class="review-panel" data-review-panel="clear" style="padding:24px">
        @if (clearRows.Any())
        {
            <div class="alert alert--info" style="margin-bottom:16px">Showing @clearRows.Count.ToString("N0") CLEAR sample row(s).</div>
            <div class="r21-table-wrap">
                <table class="r21-table">
                    <thead>
                        <tr>
                            <th>#</th><th>STUD Qual Ref</th><th>STUD _007</th><th>FTE Value</th>
                            <th>QUAL Code</th><th>QUAL Name</th><th>Result</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in clearRows)
                        {
                            <tr class="is-clear">
                                <td>@row.RowNumber</td>
                                <td>@row.StudQualRef</td>
                                <td>@row.Stud007Value</td>
                                <td>@row.Stud010Value</td>
                                <td>@row.QualCodeValue</td>
                                <td>@row.QualNameValue</td>
                                <td class="is-clear-text">CLEAR</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert--info">No CLEAR sample rows were saved in this run.</div>
        }
    </div>

    <div class="review-panel" data-review-panel="visuals" style="padding:24px">
        <div class="viz-grid">
            <div class="viz-card">
                <div style="font-size:12px;text-transform:uppercase;font-weight:700;color:#64748b">Validation Results</div>
                <div style="height:220px;display:flex;align-items:flex-end;justify-content:center;gap:36px;padding:12px 0 6px">
                    <div style="text-align:center">
                        <div style="width:110px;height:@(flaggedH.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))px;background:#ef4444;border:2px solid #1f2937;display:flex;align-items:flex-start;justify-content:center;padding-top:8px;font-weight:700;color:#fff">@flaggedCount.ToString("N0")</div>
                        <div style="margin-top:8px;font-size:13px">FLAGGED</div>
                    </div>
                    <div style="text-align:center">
                        <div style="width:110px;height:@(clearH.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))px;background:#4caf50;border:2px solid #1f2937;display:flex;align-items:flex-start;justify-content:center;padding-top:8px;font-weight:700;color:#fff">@clearCount.ToString("N0")</div>
                        <div style="margin-top:8px;font-size:13px">CLEAR</div>
                    </div>
                </div>
            </div>
            <div class="viz-card">
                <div style="font-size:12px;text-transform:uppercase;font-weight:700;color:#64748b">Exception Rate</div>
                <div style="display:flex;align-items:center;justify-content:center;height:220px">
                    <div style="font-size:48px;font-weight:800;color:@complianceColor">@rate.ToString("F2")%</div>
                </div>
                <div style="text-align:center;font-size:13px;color:#64748b">@flaggedCount.ToString("N0") of @total.ToString("N0") FTE students flagged</div>
            </div>
        </div>
    </div>

    <div class="review-panel" data-review-panel="sql" style="padding:24px">
        <div class="code-panel">
            <pre>@Model.GeneratedSql</pre>
        </div>
    </div>

    @if (canDownload)
    {
        <div class="review-panel" data-review-panel="downloads" style="padding:24px">
            <div style="display:flex;gap:12px;flex-wrap:wrap">
                <a href="@Url.Action("DownloadSavedExcel", new { runId = Model.RunId })" class="btn btn-secondary">Download Excel</a>
                <a href="@Url.Action("DownloadSavedCsv", new { runId = Model.RunId })" class="btn btn-secondary">Download CSV (All)</a>
                <a href="@Url.Action("DownloadSavedExceptionsCsv", new { runId = Model.RunId })" class="btn btn-secondary">Download CSV (FLAGGED only)</a>
                <a href="@Url.Action("DownloadSavedSql", new { runId = Model.RunId })" class="btn btn-secondary">Download SQL</a>
            </div>
        </div>
    }
</div>

<script>
    document.querySelectorAll('.review-tab').forEach(tab => {
        tab.addEventListener('click', function () {
            const panel = this.dataset.reviewTab;
            document.querySelectorAll('.review-tab').forEach(t => t.classList.remove('is-active'));
            document.querySelectorAll('.review-panel').forEach(p => p.classList.remove('is-active'));
            this.classList.add('is-active');
            document.querySelector(`[data-review-panel="${panel}"]`).classList.add('is-active');
        });
    });
</script>
